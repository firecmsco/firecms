{
    "name": "@rebasepro/postgresql-backend",
    "type": "module",
    "version": "0.0.1",
    "description": "PostgreSQL data source backend implementation for Rebase with Drizzle ORM",
    "funding": {
        "url": "https://github.com/sponsors/rebaseco"
    },
    "author": "Rebase",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/rebasepro/rebase.git",
        "directory": "packages/postgresql-backend"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/postgresql-backend/src/index.d.ts",
    "source": "src/index.ts",
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "cms",
        "admin",
        "postgresql",
        "database",
        "drizzle",
        "backend",
        "rebase"
    ],
    "scripts": {
        "watch": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json",
        "prepublishOnly": "run-s build",
        "test:lint": "eslint \"src/**\" --quiet",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.tsx?$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "moduleNameMapper": {
            "^@rebasepro/common$": "<rootDir>/../common/src/index.ts",
            "^@rebasepro/types$": "<rootDir>/../types/src/index.ts",
            "^@rebasepro/utils$": "<rootDir>/../utils/src/index.ts"
        }
    },
    "exports": {
        ".": {
            "types": "./dist/postgresql-backend/src/index.d.ts",
            "development": "./src/index.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@rebasepro/common": "0.0.1",
        "@rebasepro/types": "0.0.1",
        "@rebasepro/utils": "0.0.1",
        "arg": "^5.0.2",
        "chalk": "^4.1.2",
        "drizzle-orm": "^0.44.4",
        "execa": "^4.1.0",
        "pg": "^8.11.3"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^20.10.5",
        "@types/pg": "^8.6.5",
        "drizzle-kit": "^0.31.4",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.5",
        "typescript": "^5.0.0",
        "vite": "^5.0.0"
    },
    "gitHead": "d935eefa5aa8d1009a2398cfac2c1e4ee9aeb6b6",
    "publishConfig": {
        "access": "public"
    }
}

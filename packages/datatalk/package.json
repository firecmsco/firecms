{
    "name": "@rebasepro/datatalk",
    "version": "0.0.1-canary.0",
    "description": "Talk to your Firestore data",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@rebasepro/core": "0.0.1-canary.0",
        "@rebasepro/data_export": "0.0.1-canary.0",
        "@rebasepro/data_import": "0.0.1-canary.0",
        "@rebasepro/data_import_export": "0.0.1-canary.0",
        "@rebasepro/firebase": "0.0.1-canary.0",
        "@rebasepro/formex": "0.0.1-canary.0",
        "@rebasepro/schema_inference": "0.0.1-canary.0",
        "@rebasepro/studio": "4.0.0",
        "@rebasepro/types": "0.0.1-canary.0",
        "@rebasepro/ui": "0.0.1-canary.0"
    },
    "devDependencies": {
        "@types/node": "20.19.17",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "typescript": "^5.9.3",
        "vite": "^7.2.4"
    },
    "gitHead": "e42be25c08d53e4b59790f8619ba848cce455363"
}

{
  "include": ["./src/**/*"],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "declarationMap": false,
    "outDir": "dist",
    "alwaysStrict": false,
    "module": "ESNEXT",
    "target": "ESNEXT",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "vite/client",
      "node",
      "jest"
    ],
    "baseUrl": ".",
    "paths": {
      "@rebasepro/ui": [
        "../ui/src"
      ],
      "@rebasepro/core": [
        "../core/src"
      ],
      "@rebasepro/types": [
        "../types/src"
      ],
      "@rebasepro/firebase": [
        "../firebase/src"
      ],
      "@rebasepro/formex": [
        "../formex/src"
      ],

      "@rebasepro/schema_inference": [
        "../schema_inference/src"
      ],
      "@rebasepro/data_import": [
        "../data_import/src"
      ],
      "@rebasepro/data_export": [
        "../data_export/src"
      ],

      "@rebasepro/data_import_export": [
        "../data_import_export/src"
      ],
      "@rebasepro/cms": [
        "../cms/src"
      ],
      "@rebasepro/common": [
        "../common/src"
      ]
    }
  }
}


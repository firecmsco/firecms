{
    "name": "@firecms/postgresql",
    "type": "module",
    "version": "4.0.0",
    "description": "PostgreSQL data source client for FireCMS",
    "funding": {
        "url": "https://github.com/sponsors/firecmsco"
    },
    "author": "FireCMS",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/firecmsco/firecms.git",
        "directory": "packages/postgresql"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "source": "src/index.ts",
    "engines": {
        "node": ">=14"
    },
    "keywords": [
        "firebase",
        "cms",
        "admin",
        "admin panel",
        "postgresql",
        "database",
        "firecms",
        "client"
    ],
    "scripts": {
        "watch": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json",
        "prepublishOnly": "run-s build",
        "test:lint": "eslint \"src/**\" --quiet",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.tsx?$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "moduleNameMapper": {
            "^@firecms/core$": "<rootDir>/../firecms_core/src/index.ts",
            "^@firecms/common$": "<rootDir>/../common/src/index.ts",
            "^@firecms/types$": "<rootDir>/../types/src/index.ts"
        }
    },
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@firecms/types": "4.0.0",
        "@firecms/core": "4.0.0"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "typescript": "^5.0.0",
        "vite": "^5.0.0",
        "@types/jest": "^29.5.14",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.5"
    }
}

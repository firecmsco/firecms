{
  "name": "@rebasepro/mongodb",
  "type": "module",
  "version": "0.0.1-canary.0",
  "description": "MongoDB backend for Rebase",
  "funding": {
    "url": "https://github.com/sponsors/rebaseco"
  },
  "author": "Rebase",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rebaseco/rebase.git",
    "directory": "packages/mongodb"
  },
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/mongodb/src/index.d.ts",
  "source": "src/index.ts",
  "engines": {
    "node": ">=14"
  },
  "keywords": [
    "firebase",
    "cms",
    "admin",
    "admin panel",
    "mongodb",
    "backend",
    "database",
    "rebase"
  ],
  "scripts": {
    "watch": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json",
    "prepublishOnly": "run-s build",
    "test:lint": "eslint \"src/**\" --quiet",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/mongodb/src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@rebasepro/core": "0.0.1-canary.0",
    "@rebasepro/types": "0.0.1-canary.0",
    "mongodb": "^6.12.0",
    "realm-web": "^2.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@rebasepro/types": "4.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "ts-jest": "29.4.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "@rebasepro/backend": "4.0.0"
  },
  "peerDependenciesMeta": {
    "@rebasepro/backend": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "gitHead": "2865a45f2dced914d4d1e3dda735659628f0e4cb",
  "publishConfig": {
    "access": "public"
  }
}

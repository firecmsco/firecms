{
    "name": "@rebasepro/server-mongodb",
    "type": "module",
    "version": "0.0.1",
    "description": "MongoDB backend for Rebase",
    "funding": {
        "url": "https://github.com/sponsors/rebaseco"
    },
    "author": "Rebase",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/rebasepro/rebase.git",
        "directory": "packages/server-mongodb"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/server-mongodb/src/index.d.ts",
    "source": "src/index.ts",
    "engines": {
        "node": ">=14"
    },
    "keywords": [
        "firebase",
        "cms",
        "admin",
        "admin panel",
        "mongodb",
        "backend",
        "database",
        "rebase"
    ],
    "scripts": {
        "watch": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json",
        "prepublishOnly": "run-s build",
        "test:lint": "eslint \"src/**\" --quiet",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
    },
    "exports": {
        ".": {
            "types": "./dist/server-mongodb/src/index.d.ts",
            "development": "./src/index.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@rebasepro/types": "0.0.1",
        "mongodb": "^6.12.0",
        "realm-web": "^2.0.0"
    },
    "devDependencies": {
        "@rebasepro/types": "0.0.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.10.5",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^10.0.0",
        "ts-jest": "29.4.1",
        "typescript": "^5.0.0",
        "vite": "^5.0.0"
    },
    "peerDependencies": {
        "@rebasepro/server-core": "0.0.1"
    },
    "peerDependenciesMeta": {
        "@rebasepro/server-core": {
            "optional": true
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "gitHead": "d935eefa5aa8d1009a2398cfac2c1e4ee9aeb6b6",
    "publishConfig": {
        "access": "public"
    }
}

{
  "name": "@firecms/cli",
  "version": "3.3.0",
  "description": "A CLI to perform FireCMS operations",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "source": "src/index.ts",
  "bin": {
    "firecms": "bin/firecms.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rm -rf templates/template_cloud/node_modules && rm -rf templates/template_cloud/yarn.lock && rm -rf templates/template_astro/node_modules && rm -rf templates/template_astro/dist && rm -rf templates/template_astro/.astro && vite build && tsc --emitDeclarationOnly -p tsconfig.json",
    "dev": "ts-node src/test.ts",
    "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f"
  },
  "keywords": [
    "cli",
    "create-firecms-app",
    "firecms",
    "firebase",
    "firestore",
    "cms",
    "react",
    "typescript"
  ],
  "author": "firecms.co",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "arg": "^5.0.2",
    "axios": "^1.16.1",
    "chalk": "^4.1.2",
    "execa": "^9.6.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.0",
    "googleapis": "^166.0.0",
    "inquirer": "12.11.1",
    "json5": "^2.2.3",
    "listr2": "^8.3.3",
    "nocache": "^4.0.0",
    "open": "^10.2.0",
    "ora": "^8.2.0",
    "pump": "^3.0.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "npm-run-all2": "^6.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wsl-utils": "^0.1.0"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "templates/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "exclude": [
    "node_modules",
    "template/node_modules"
  ],
  "gitHead": "9ecf37abf793bd2f2daaaed6f517ee5ee19b01ae",
  "repository": {
    "type": "git",
    "url": "https://github.com/FireCMSco/firecms.git",
    "directory": "packages/cli"
  }
}

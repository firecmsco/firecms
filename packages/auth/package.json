{
    "name": "@rebasepro/auth",
    "type": "module",
    "version": "0.0.1-canary.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "Custom JWT authentication for Rebase with PostgreSQL backend",
    "main": "./dist/index.umd.js",

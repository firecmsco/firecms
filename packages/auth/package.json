            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "devDependencies": {
        "@types/node": "^20.19.17",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "typescript": "^5.9.3",
        "vite": "^7.2.4"
    },
    "scripts": {
        "dev": "vite",

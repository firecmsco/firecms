{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@firecms/core": ["../firecms_core/dist"],
      "@firecms/firebase": ["../firebase_firecms/dist"],
      "@firecms/ui": ["../ui/dist"],
      "@firecms/collection_editor": ["../collection_editor/dist"],
      "@firecms/collection_editor_firebase": ["../collection_editor_firebase/dist"],
      "@firecms/user_management": ["../user_management/dist"],
      "@firecms/data_enhancement": ["../data_enhancement/dist"],
      "@firecms/datatalk": ["../datatalk/dist"],
      "@firecms/schema_inference": ["../schema_inference/dist"],
      "@firecms/data_import": ["../data_import/dist"],
      "@firecms/data_export": ["../data_export/dist"],
      "@firecms/entity_history": ["../entity_history/dist"],
      "@firecms/data_import_export": ["../data_import_export/dist"],
      "@firecms/formex": ["../formex/dist"],
      "@firecms/firebase_admin": ["../firebase_admin/dist"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "../firecms_core/src",
    "../ui/src",
    "../collection_editor/src",
    "../collection_editor_firebase/src",
    "../data_enhancement/src",
    "../schema_inference/src",
    "../user_management/src",
    "../formex/src",
    "../datatalk/src",
    "../entity_history/src",
    "../data_import_export/src"
  ]
}

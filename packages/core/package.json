{
    "name": "@rebasepro/core",
    "type": "module",
    "version": "0.0.1",
    "description": "Rebase core — framework-agnostic runtime for data-driven admin panels",
    "funding": {
        "url": "https://github.com/sponsors/rebaseco"
    },
    "author": "Rebase",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/rebasepro/rebase.git",
        "directory": "packages/core"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "source": "src/index.ts",
    "engines": {
        "node": ">=14"
    },
    "keywords": [
        "firebase",
        "cms",
        "admin",
        "admin panel",
        "firebase panel",
        "firestore",
        "headless",
        "headless cms",
        "content manager"
    ],
    "scripts": {
        "watch": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json && npx esbuild src/vitePlugin.ts --platform=node --format=esm --outfile=dist/vitePlugin.js",
        "prepublishOnly": "run-s build",
        "test:lint": "eslint \"src/**\" --quiet",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f",
        "generateIcons": "ts-node --esm src/icons/generateIcons.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./src/index.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        },
        "./vitePlugin": {
            "types": "./dist/vitePlugin.d.ts",
            "development": "./src/vitePlugin.ts",
            "import": "./dist/vitePlugin.js",
            "require": "./dist/vitePlugin.js"
        },
        "./package.json": "./package.json"
    },
    "dependencies": {

        "@rebasepro/client": "0.0.1",
        "@rebasepro/common": "0.0.1",
        "@rebasepro/formex": "0.0.1",
        "@rebasepro/types": "0.0.1",
        "@rebasepro/ui": "0.0.1",
        "compressorjs": "^1.2.1",
        "fast-equals": "5.3.0",
        "fuse.js": "^7.1.0",
        "history": "^5.3.0",
        "i18next": "^23.16.4",
        "notistack": "^3.0.2",
        "react-i18next": "^14.1.3",
        "@rebasepro/utils": "workspace:*"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0",
        "react-router": "^7.0.0",
        "react-router-dom": "^7.0.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.19.17",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "@types/react-measure": "^2.0.12",
        "@vitejs/plugin-react": "^4.3.4",
        "babel-plugin-react-compiler": "beta",
        "cross-env": "^7.0.3",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "npm-run-all": "^4.1.5",
        "react-router": "^7.0.0",
        "react-router-dom": "^7.0.0",
        "ts-jest": "^29.4.5",
        "ts-node": "^10.9.2",
        "tsd": "^0.31.2",
        "typescript": "^5.9.3",
        "vite": "^7.2.4"
    },
    "files": [
        "dist",
        "src"
    ],
    "gitHead": "d935eefa5aa8d1009a2398cfac2c1e4ee9aeb6b6",
    "publishConfig": {
        "access": "public"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.tsx?$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "testEnvironment": "jsdom",
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/src/components/",
            "objects.test.ts",
            "navigation.test.ts",
            "resolutions.test.ts"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/test/setupTests.ts"
        ],
        "moduleNameMapper": {
            "\\.(css|less)$": "<rootDir>/test/__mocks__/styleMock.js",
            "^@rebasepro/ui$": "<rootDir>/../ui/src/index.ts",
            "^@rebasepro/common$": "<rootDir>/../common/src/index.ts",
            "^@rebasepro/types$": "<rootDir>/../types/src/index.ts",
            "^@rebasepro/formex$": "<rootDir>/../formex/src/index.ts"
        }
    }
}
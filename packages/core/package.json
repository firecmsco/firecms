{
    "name": "@rebasepro/core",
    "type": "module",
    "version": "0.0.1",
    "description": "Awesome Firebase/Firestore-based headless open-source CMS",
    "funding": {
        "url": "https://github.com/sponsors/rebaseco"
    },
    "author": "Rebase",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/rebaseco/rebase.git",
        "directory": "packages/core"
    },
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "source": "src/index.ts",
    "engines": {
        "node": ">=14"
    },
    "keywords": [
        "firebase",
        "cms",
        "admin",
        "admin panel",
        "firebase panel",
        "firestore",
        "headless",
        "headless cms",
        "content manager"
    ],
    "scripts": {
        "watch": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.prod.json && npx esbuild src/vitePlugin.ts --platform=node --format=esm --outfile=dist/vitePlugin.js",
        "prepublishOnly": "run-s build",
        "test:lint": "eslint \"src/**\" --quiet",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf dist && find ./src -name '*.js' -type f | xargs rm -f",
        "generateIcons": "ts-node --esm src/icons/generateIcons.ts"
    },
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "import": "./dist/index.es.js",
            "types": "./dist/index.d.ts",
            "require": "./dist/index.umd.js"
        },
        "./vitePlugin": {
            "development": "./src/vitePlugin.ts",
            "types": "./dist/vitePlugin.d.ts",
            "import": "./dist/vitePlugin.js",
            "require": "./dist/vitePlugin.js"
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@floating-ui/dom": "^1.7.4",
        "@radix-ui/react-portal": "^1.1.10",
        "@radix-ui/react-slot": "^1.2.4",
        "@rebasepro/common": "0.0.1",
        "@rebasepro/formex": "0.0.1",
        "@rebasepro/types": "0.0.1",
        "@rebasepro/ui": "0.0.1",
        "clsx": "^2.1.1",
        "compressorjs": "^1.2.1",
        "date-fns": "^3.6.0",
        "fast-equals": "5.3.0",
        "fuse.js": "^7.1.0",
        "history": "^5.3.0",
        "i18next": "^23.16.4",
        "json-logic-js": "^2.0.5",
        "markdown-it": "^14.1.0",
        "markdown-it-ins": "^4.0.0",
        "markdown-it-mark": "^4.0.0",
        "markdown-it-task-lists": "^2.1.1",
        "notistack": "^3.0.2",
        "object-hash": "^3.0.0",
        "prism-react-renderer": "^2.4.1",
        "prosemirror-commands": "^1.6.0",
        "prosemirror-dropcursor": "^1.8.1",
        "prosemirror-gapcursor": "^1.3.2",
        "prosemirror-history": "^1.4.1",
        "prosemirror-inputrules": "^1.5.1",
        "prosemirror-keymap": "^1.2.2",
        "prosemirror-markdown": "^1.13.0",
        "prosemirror-model": "^1.22.3",
        "prosemirror-schema-list": "^1.4.1",
        "prosemirror-state": "^1.4.3",
        "prosemirror-tables": "^1.8.5",
        "prosemirror-transform": "^1.10.0",
        "prosemirror-view": "^1.33.8",
        "react-dropzone": "^14.3.8",
        "react-i18next": "^14.1.3",
        "react-markdown": "^9.1.0",
        "react-transition-group": "^4.4.5",
        "react-use-measure": "^2.1.7",
        "react-window": "^1.8.11",
        "vite-plugin-static-copy": "3.1.4",
        "yup": "^1.7.1"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0",
        "react-router": "^7.0.0",
        "react-router-dom": "^7.0.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^29.5.14",
        "@types/json-logic-js": "^2.0.8",
        "@types/node": "^20.19.17",
        "@types/object-hash": "^3.0.6",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "@types/react-measure": "^2.0.12",
        "@vitejs/plugin-react": "^4.3.4",
        "babel-plugin-react-compiler": "beta",
        "cross-env": "^7.0.3",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "npm-run-all": "^4.1.5",
        "react-router": "^7.0.0",
        "react-router-dom": "^7.0.0",
        "ts-jest": "^29.4.5",
        "ts-node": "^10.9.2",
        "tsd": "^0.31.2",
        "typescript": "^5.9.3",
        "vite": "^7.2.4"
    },
    "files": [
        "dist",
        "src"
    ],
    "gitHead": "d935eefa5aa8d1009a2398cfac2c1e4ee9aeb6b6",
    "publishConfig": {
        "access": "public"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.tsx?$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "testEnvironment": "jsdom",
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/src/components/",
            "objects.test.ts",
            "navigation.test.ts",
            "resolutions.test.ts"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/test/setupTests.ts"
        ],
        "moduleNameMapper": {
            "\\.(css|less)$": "<rootDir>/test/__mocks__/styleMock.js",
            "^@rebasepro/ui$": "<rootDir>/../ui/src/index.ts",
            "^@rebasepro/common$": "<rootDir>/../common/src/index.ts",
            "^@rebasepro/types$": "<rootDir>/../types/src/index.ts",
            "^@rebasepro/formex$": "<rootDir>/../formex/src/index.ts"
        }
    }
}

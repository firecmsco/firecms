{
    "name": "rebase-parent",
    "private": true,
    "description": "Open-source headless CMS and admin panel for Postgres",
    "author": "Rebase",
    "repository": {
        "type": "git",
        "url": "https://github.com/rebasepro/rebase.git"
    },
    "homepage": "https://rebase.pro",
    "workspaces": [
        "packages/types",
        "packages/utils",
        "packages/common",
        "packages/formex",
        "packages/ui",
        "packages/core",
        "packages/client",
        "packages/server-core",
        "packages/auth",
        "packages/cli",
        "packages/studio",
        "packages/cms",
        "packages/client-postgresql",
        "packages/server-postgresql",
        "packages/server-mongodb",
        "packages/client-firebase",
        "packages/plugin-data-enhancement",
        "packages/schema-inference",
        "packages/sdk-generator",
        "packages/mcp-server",
        "app",
        "app/frontend",
        "app/backend",
        "app/shared"
    ],
    "scripts": {
        "test": "pnpm -r test",
        "dev": "cd app && run-s dev",
        "web": "cd website && run-s dev",
        "deploy:web": "cd website && run-s deploy",
        "build": "pnpm --filter './packages/*' -r run build && pnpm --filter './app' -r run build",
        "build:stream": "lerna run build --stream --loglevel=info",
        "clean": "lerna run clean",
        "release": "git push origin main:release",
        "e2e": "npx tsx e2e/runner.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@types/eslint__js": "^8.42.3",
        "@types/json-logic-js": "2.0.8",
        "@typescript-eslint/eslint-plugin": "^8.17.0",
        "eslint": "^9.24.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-n": "^17.14.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^16.4.0",
        "lerna": "^9.0.3",
        "npm-run-all": "^4.1.5",
        "ts-morph": "27.0.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.29.0"
    },
    "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67"
}

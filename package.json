{
  "name": "firecms-parent",
  "private": true,
  "description": "Awesome Firebase/Firestore-based headless open-source CMS",
  "author": "FireCMS",
  "repository": {
    "type": "git",
    "url": "https://github.com/FireCMSco/firecms.git"
  },
  "homepage": "https://firecms.co",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "cd examples/example && run-s dev",
    "pro": "cd examples/example_pro && run-s dev",
    "next": "cd examples/example_next && run-s dev",
    "cloud": "cd examples/example_cloud && run-s dev",
    "saas:staging": "cd saas && run-s dev:staging",
    "saas": "cd saas && run-s dev:prod",
    "datatalk": "cd saas_datatalk && run-s dev",
    "discord-bot": "cd discord-bot && pnpm run start",
    "discord-bot:dev": "cd discord-bot && pnpm run dev",
    "deploy:demo": "cd examples/example_pro && run-s deploy",
    "preview": "cd examples/example_pro && run-s preview",
    "deploy:staging": "lerna run build && cd saas && run-s deploy:staging",
    "deploy:prod": "lerna run build && cd saas && run-s deploy:prod && cd .. && run-s create-prod-release-tag",
    "create-prod-release-tag": "git tag -a \"release_$(date +'%Y%m%d-%H%M')\" -m \"Prod release on $(date +'%Y-%m-%d %H:%M')\"",
    "deploy:canary": "lerna run build && cd saas && run-s build && run-s deploy:canary",
    "web": "cd website && run-s dev",
    "deploy:web": "cd website && run-s deploy",
    "build": "lerna run build",
    "build:stream": "lerna run build --stream --loglevel=info",
    "clean": "lerna run clean",
    "release": "git push origin main:release"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "lerna": "^9.0.3",
    "npm-run-all2": "^6.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}

---
import Layout from "../layouts/Layout.astro";
import ScrollSyncShowcase from "./ScrollSyncShowcase.astro";

import SpotlightCard from "./SpotlightCard.astro";
import SectionBackgroundAccents from "./SectionBackgroundAccents.astro";

import { useTranslatedPath } from "../i18n/utils";

const { lang, t } = Astro.props;
const tp = useTranslatedPath(lang as any);
---

<main>

    <section
            class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-24 sm:pt-32 sm:pb-32 lg:pt-48 lg:pb-48">

        <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
            <h1 class="mb-8 text-5xl sm:text-6xl font-extrabold tracking-tight leading-none md:text-6xl lg:text-6xl text-white font-sans">
                {t('hero.title.1')}<br/> {t('hero.title.2')} <span class="text-orange-500 subtle-shimmer">Firebase</span>
            </h1>
            <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-64">
                {t('hero.subtitle.1')}<br/>
                {t('hero.subtitle.2')} <b>{t('hero.subtitle.3')}</b>, {t('hero.subtitle.4')} <b>{t('hero.subtitle.5')}</b> {t('hero.subtitle.6')} </p>
            <div class="flex items-center justify-center gap-x-6">
                <a href="https://app.firecms.co"
                   data-track
                   id="hero-start-building"
                   class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                    {t('hero.cta.start')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-5 w-5 text-white filter invert"/>
                </a>
                <a href="/developers"
                   data-track
                   id="hero-explore-self-hosted"
                   class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-900/50 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-surface-700 transition-all duration-200 ease-in-out">
                    {t('hero.cta.explore')}
                </a>
            </div>

        </div>

    </section>

    <!-- Social Proof Section with gradient divider -->
    <section class="relative isolate bg-black py-16 overflow-hidden">
        <SectionBackgroundAccents topLine={true} blob={{
            position: "top",
            size: "sm"
        }}/>


        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <p class="text-center text-lg font-semibold leading-8 text-surface-400 mb-10 animate-on-scroll fade-in">
                {t('social.trusted')}
            </p>
            <div class="mx-auto flex items-center justify-center gap-x-12 gap-y-8 flex-wrap max-w-2xl animate-on-scroll scale-in ">
                <img src="/img/logos/Google_2015_logo.svg" alt="Google"
                     class="h-10 w-auto opacity-50 hover:opacity-80 transition-opacity grayscale"/>
                <img src="/img/logos/Microsoft_logo_%282012%29.svg" alt="Microsoft"
                     class="h-8 w-auto opacity-50 hover:opacity-80 transition-opacity grayscale"/>
                <img src="/img/logos/Ikea_logo.svg" alt="IKEA"
                     class="h-10 w-auto opacity-50 hover:opacity-80 transition-opacity grayscale"/>
            </div>
            <p class="text-center text-sm text-surface-500 mt-8 animate-on-scroll fade-in ">{t('social.more')}</p>

        </div>
    </section>

    <!-- What Can You Build Section with icon accents -->
    <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
        <SectionBackgroundAccents topLine={true}/>

        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="w-full lg:w-[400px] mb-20 mt-16 animate-on-scroll fade-in-up">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('usecases.title.1')}<br/> {t('usecases.title.2')}</h2>
                <p class="mt-6 text-lg leading-8 text-surface-400">{t('usecases.subtitle')}</p>
            </div>
            <div class="mx-auto mt-16 max-w-7xl">
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg"
                            title={t('usecases.card1.title')}
                            description={t('usecases.card1.desc')}
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layout-dashboard.svg"
                            title={t('usecases.card2.title')}
                            description={t('usecases.card2.desc')}
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg"
                            title={t('usecases.card3.title')}
                            description={t('usecases.card3.desc')}
                    />
                </div>
            </div>
        </div>
    </section>

    <section class="flex flex-col items-center justify-center bg-black py-16 sm:py-24">
        <!-- Google Cloud Partner Badge -->
        <div class="mt-2 flex justify-center animate-on-scroll fade-in">
            <a href="https://cloud.google.com/partners" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-3 px-4 py-1 rounded-full border border-surface-800 bg-surface-900/50 hover:bg-surface-800 transition-all duration-200"
               title="Google Cloud Partner">
                <img src="/img/logos/google_cloud_partner.svg" alt="Google Cloud Partner" class="h-8 w-auto"/>
            </a>
        </div>

    </section>

    <!-- Scroll-sync showcase (sticky index on the right) -->
    <ScrollSyncShowcase lang={lang}/>

    <section class="bg-black py-16 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">

            <p class="text-center text-sm font-medium text-surface-500 mb-8 uppercase tracking-wider">
                {t('tech.title')}
            </p>

            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 sm:gap-x-12 lg:gap-x-16">

                <img class="h-10 w-auto opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                     src="/img/reactjs-icon.svg" alt="React">

                <img class="h-10 w-auto opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                     src="/img/typescript_logo.svg" alt="TypeScript">

                <img class="h-8 w-auto opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                     src="/img/tailwind_logo.svg" alt="Tailwind CSS">

                <img class="h-10 w-auto opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                     src="/img/firebase.svg" alt="Firebase">

            </div>
        </div>
    </section>

    <!-- Persona Routing Section with subtle accents -->
    <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
        <SectionBackgroundAccents topLine={true} blob={{
            position: "bottom",
            size: "md"
        }}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('personas.title')}</h2>
            </div>
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                <SpotlightCard
                        icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/rocket.svg"
                        title={t('personas.startup.title')}
                        description={t('personas.startup.desc')}
                        link={{
                            href: "/startups",
                            text: t('personas.startup.link')
                        }}
                />
                <SpotlightCard
                        icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/briefcase.svg"
                        title={t('personas.agency.title')}
                        description={t('personas.agency.desc')}
                        link={{
                            href: "/agencies",
                            text: t('personas.agency.link')
                        }}
                />
                <SpotlightCard
                        icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code.svg"
                        title={t('personas.dev.title')}
                        description={t('personas.dev.desc')}
                        link={{
                            href: "/developers",
                            text: t('personas.dev.link')
                        }}
                />
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="bg-black py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6">
            <div class="mx-auto max-w-3xl text-center animate-on-scroll fade-in-up">
                <h2 class="text-3xl sm:text-4xl font-medium text-white">{t('faq.title')}</h2>
            </div>
            <div class="mt-10 max-w-3xl mx-auto space-y-4 animate-on-scroll fade-in-up delay-100">
                <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                    <summary class="cursor-pointer text-white font-semibold">{t('faq.q1.q')}
                    </summary>
                    <p class="mt-2 text-surface-300">{t('faq.q1.a')}</p>
                </details>
                <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                    <summary class="cursor-pointer text-white font-semibold">{t('faq.q2.q')}
                    </summary>
                    <p class="mt-2 text-surface-300">{t('faq.q2.a')}</p>
                </details>
                <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                    <summary class="cursor-pointer text-white font-semibold">{t('faq.q3.q')}
                    </summary>
                    <p class="mt-2 text-surface-300">{t('faq.q3.a')}</p>
                </details>
                <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                    <summary class="cursor-pointer text-white font-semibold">{t('faq.q4.q')}</summary>
                    <p class="mt-2 text-surface-300">{t('faq.q4.a')}</p>
                </details>
                <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                    <summary class="cursor-pointer text-white font-semibold">{t('faq.q5.q')}</summary>
                    <p class="mt-2 text-surface-300">{t('faq.q5.a')}</p>
                </details>
            </div>
        </div>
    </section>

    <section class="relative isolate bg-black py-32 sm:py-48 border-t border-surface-800">
        <SectionBackgroundAccents blob={{
            position: "bottom",
            size: "md",
            opacity: 50
        }}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">

            <!-- Minimalistic single quote (Microsoft) -->
            <div class="mx-auto max-w-3xl animate-on-scroll fade-in-up">
                <figure>
                    <blockquote class="text-2xl sm:text-3xl leading-snug text-white tracking-tight">
                        {t('testimonial.quote')}
                    </blockquote>
                    <figcaption class="mt-6 flex items-center gap-x-4">
                        <img class="h-12 w-12 rounded-full bg-surface-800 object-cover"
                             src="/img/avatars/fulei.avif" alt="Fulei Huang">
                        <div class="text-sm leading-6">
                            <div class="font-semibold text-white">Fulei Huang</div>
                            <div class="text-surface-400">Software Engineer, Microsoft</div>
                        </div>
                    </figcaption>
                </figure>
            </div>

            <div class="mt-16 text-center">
                <a href="/features"
                   class="text-base font-semibold leading-6 text-primary-light hover:text-primary transition-colors">
                    {t('features.link')} <span aria-hidden="true">→</span>
                </a>
            </div>
        </div>
    </section>

    <!-- Final CTA with background accents -->
    <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
        <SectionBackgroundAccents topLine={true} blob={{
            position: "top",
            size: "lg"
        }}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-8 animate-on-scroll fade-in-up">
                {t('cta.title')}</h2>
            <div class="flex items-center justify-center gap-x-6 animate-on-scroll fade-in-up delay-100">
                <a href="https://app.firecms.co"
                   data-track
                   id="cta-try-cloud"
                   class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                    {t('cta.cloud')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-5 w-5 text-white filter invert"/>
                </a>
                <a href={tp("/docs")}
                   data-track
                   id="cta-view-docs"
                   class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
                    {t('cta.docs')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-4 w-4 text-white filter invert"/>
                </a>
            </div>
        </div>
    </section>


</main>

---
// src/components/pages/AgenciesContent.astro
import ClientLogos from "../ClientLogos.astro";
import SectionBackgroundAccents from "../SectionBackgroundAccents.astro";
import BrowserFrame from "../BrowserFrame.astro";
import UsageExamples from "../UsageExamples.astro";

const { lang, t } = Astro.props;
---

<main class="flex-grow">
    <!-- Hero Section -->
    <section
            class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24">
        <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
            <h1 class="mb-6 text-4xl font-medium tracking-tight md:text-5xl lg:text-6xl text-white font-sans animate-on-scroll fade-in-up" set:html={t('agencies.hero.title')}></h1>
            <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-48 animate-on-scroll fade-in-up delay-100" set:html={t('agencies.hero.subtitle')}></p>
        </div>
    </section>

    <section class="relative isolate bg-black py-16">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-8 lg:px-12">
            <div class="mx-auto mt-4 mb-8 animate-on-scroll fade-in">
                <ClientLogos filter="agencies"/>
            </div>
        </div>
    </section>


    <!-- Agency Advantage Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-4xl text-center animate-on-scroll fade-in-up">
                <div class="flex items-center justify-center mb-4">
                    <h3 class="m-0 text-3xl font-bold text-white">
                        {t('agencies.weapon.title')}
                    </h3>
                </div>
                <p class="text-xl md:text-2xl mb-4 text-surface-300">
                    {t('agencies.weapon.desc1')}
                </p>
                <p class="text-lg text-surface-400">
                    {t('agencies.weapon.desc2')}
                </p>
            </div>
        </div>
    </section>


    <UsageExamples lang={lang} t={t} />


    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center animate-on-scroll fade-in-up delay-100">
                <div class="lg:col-span-6">
                    <div class="text-center mb-12 animate-on-scroll fade-in-up">
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('agencies.accelerate.title')}</h2>
                    </div>
                    <div class="flex items-start gap-4 mb-6">
                        <div class="h-10 w-10 rounded-lg bg-green-500/15 flex items-center justify-center">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/bolt.svg" alt="Speed"
                                 class="h-6 w-6 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-xl font-semibold text-white mb-1">{t('agencies.accelerate.f1.title')}</h3>
                            <p class="text-surface-400">{t('agencies.accelerate.f1.desc')}</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 mb-6">
                        <div class="h-10 w-10 rounded-lg bg-indigo-500/15 flex items-center justify-center">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/sliders-horizontal.svg"
                                 alt="Customization" class="h-6 w-6 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-xl font-semibold text-white mb-1">{t('agencies.accelerate.f2.title')}</h3>
                            <p class="text-surface-400">{t('agencies.accelerate.f2.desc')}</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="h-10 w-10 rounded-lg bg-purple-500/15 flex items-center justify-center">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/users.svg"
                                 alt="Empower" class="h-6 w-6 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-xl font-semibold text-white mb-1">{t('agencies.accelerate.f3.title')}</h3>
                            <p class="text-surface-400">{t('agencies.accelerate.f3.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="lg:col-span-6">
                    <div
                            style={{
                                aspectRatio: 550 / 692,
                                maxHeight: "692px",
                                maxWidth: "550px"
                            }}
                            class={" flex content-center justify-center"}>
                        <img
                                class={"pointer-events-none rounded-2xl border border-surface-800 shadow-lg"}
                                width="100%"
                                alt="FireCMS entity history and audit log showing data changes over time"
                                src={"/img/history.png"}>
                        </img>
                    </div>

                </div>
            </div>
        </div>
    </section>


    <!-- Easy to Customize Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center animate-on-scroll fade-in-up">
                <div class="rounded-xl ring-1 ring-inset ring-surface-800 overflow-hidden">
                    <video
                            class="w-full h-auto"
                            loop
                            autoplay
                            muted
                            playsinline>
                        <source src="/img/custom_fields_dark_wide.mp4" type="video/mp4"/>
                    </video>
                </div>
                <div>
                    <div class="flex items-center mb-4">
                        <div class="h-10 w-10 mr-3 rounded-lg bg-primary/20 flex items-center justify-center">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/settings-2.svg"
                                 alt="Customize" class="h-6 w-6 filter invert opacity-80"/>
                        </div>
                        <h3 class="m-0 text-3xl font-bold text-white">
                            {t('agencies.customize.title')}
                        </h3>
                    </div>
                    <p class="text-xl md:text-2xl mb-4 text-surface-300">
                        {t('agencies.customize.desc1')}
                    </p>
                    <p class="text-lg text-surface-400">
                        {t('agencies.customize.desc2')}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Features for Agency Success Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('agencies.features.title')}</h2>
                <p class="text-xl text-surface-400">{t('agencies.features.subtitle')}</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Feature Items -->
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/puzzle.svg"
                                 alt="Reusable" class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f1.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f1.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/palette.svg"
                                 alt="White label" class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f2.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f2.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg"
                                 alt="Permissions" class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f3.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f3.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/rocket.svg"
                                 alt="Deployment" class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f4.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f4.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cloud.svg" alt="Cloud"
                                 class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f5.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f5.desc')}</p>
                        </div>
                    </div>
                </div>
                <div class="p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50">
                    <div class="flex items-start space-x-3">
                        <div class="h-8 w-8 rounded-md bg-surface-800 flex items-center justify-center flex-shrink-0">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code-2.svg"
                                 alt="Developer friendly" class="h-4 w-4 filter invert opacity-80"/>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-1 text-white">{t('agencies.features.f6.title')}</h3>
                            <p class="text-sm text-surface-400">{t('agencies.features.f6.desc')}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <section class="relative isolate bg-black py-10 sm:py-12">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 gap-8 sm:grid-cols-3 text-center animate-on-scroll scale-in">
                <div>
                    <div class="text-4xl font-extrabold text-white" set:html={t('agencies.metrics.m1.value')}></div>
                    <div class="mt-1 text-surface-400">{t('agencies.metrics.m1.label')}</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-white" set:html={t('agencies.metrics.m2.value')}></div>
                    <div class="mt-1 text-surface-400">{t('agencies.metrics.m2.label')}</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-white" set:html={t('agencies.metrics.m3.value')}></div>
                    <div class="mt-1 text-surface-400">{t('agencies.metrics.m3.label')}</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Agency Client Showcase Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-12 text-center text-white animate-on-scroll fade-in-up">
                {t('agencies.leverage.title')}</h2>
            <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
                <div class="group relative overflow-hidden p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50 flex flex-col transition-all duration-300 hover:ring-primary/30 animate-on-scroll scale-in"
                     data-spotlight-card>
                    <!-- Mouse spotlight effect -->
                    <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                         data-spotlight></div>

                    <div class="relative z-10">
                        <div class="flex items-center mb-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/20 mr-4 flex-shrink-0">
                                <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shopping-cart.svg"
                                     alt="E-commerce Icon"
                                     class="w-6 h-6 filter invert opacity-80"/>
                            </div>
                            <h3 class="text-xl font-semibold text-white">{t('agencies.leverage.c1.title')}</h3>
                        </div>
                        <div class="flex-grow mb-4">
                            <p class="text-sm text-surface-400 mb-2" set:html={t('agencies.leverage.c1.challenge')}></p>
                            <p class="text-sm text-white" set:html={t('agencies.leverage.c1.solution')}></p>
                        </div>
                        <div class="mt-auto pt-4 border-t border-surface-800 flex items-start">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check-circle.svg"
                                 alt="Checkmark"
                                 class="w-4 h-4 mr-2 filter invert opacity-80 flex-shrink-0 mt-0.5"/>
                            <span class="text-sm font-medium text-white" set:html={t('agencies.leverage.c1.result')}>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50 flex flex-col transition-all duration-300 hover:ring-primary/30 animate-on-scroll scale-in delay-100"
                     data-spotlight-card>
                    <!-- Mouse spotlight effect -->
                    <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                         data-spotlight></div>

                    <div class="relative z-10">
                        <div class="flex items-center mb-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/20 mr-4 flex-shrink-0">
                                <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/settings-2.svg"
                                     alt="SaaS Platform Icon"
                                     class="w-6 h-6 filter invert opacity-80"/>
                            </div>
                            <h3 class="text-xl font-semibold text-white">{t('agencies.leverage.c2.title')}</h3>
                        </div>
                        <div class="flex-grow mb-4">
                            <p class="text-sm text-surface-400 mb-2" set:html={t('agencies.leverage.c2.challenge')}></p>
                            <p class="text-sm text-white" set:html={t('agencies.leverage.c2.solution')}></p>
                        </div>
                        <div class="mt-auto pt-4 border-t border-surface-800 flex items-start">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check-circle.svg"
                                 alt="Checkmark"
                                 class="w-4 h-4 mr-2 filter invert opacity-80 flex-shrink-0 mt-0.5"/>
                            <span class="text-sm font-medium text-white" set:html={t('agencies.leverage.c2.result')}>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50 flex flex-col transition-all duration-300 hover:ring-primary/30 animate-on-scroll scale-in delay-200"
                     data-spotlight-card>
                    <!-- Mouse spotlight effect -->
                    <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                         data-spotlight></div>

                    <div class="relative z-10">
                        <div class="flex items-center mb-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/20 mr-4 flex-shrink-0">
                                <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layout-template.svg"
                                     alt="Content Marketing Icon"
                                     class="w-6 h-6 filter invert opacity-80"/>
                            </div>
                            <h3 class="text-xl font-semibold text-white">{t('agencies.leverage.c3.title')}</h3>
                        </div>
                        <div class="flex-grow mb-4">
                            <p class="text-sm text-surface-400 mb-2" set:html={t('agencies.leverage.c3.challenge')}></p>
                            <p class="text-sm text-white" set:html={t('agencies.leverage.c3.solution')}></p>
                        </div>
                        <div class="mt-auto pt-4 border-t border-surface-800 flex items-start">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check-circle.svg"
                                 alt="Checkmark"
                                 class="w-4 h-4 mr-2 filter invert opacity-80 flex-shrink-0 mt-0.5"/>
                            <span class="text-sm font-medium text-white" set:html={t('agencies.leverage.c3.result')}>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden p-8 rounded-lg ring-1 ring-inset ring-surface-800 bg-surface-900/50 flex flex-col transition-all duration-300 hover:ring-primary/30 animate-on-scroll scale-in delay-300"
                     data-spotlight-card>
                    <!-- Mouse spotlight effect -->
                    <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                         data-spotlight></div>

                    <div class="relative z-10">
                        <div class="flex items-center mb-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/20 mr-4 flex-shrink-0">
                                <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/briefcase.svg"
                                     alt="Service Business Icon"
                                     class="w-6 h-6 filter invert opacity-80"/>
                            </div>
                            <h3 class="text-xl font-semibold text-white">{t('agencies.leverage.c4.title')}</h3>
                        </div>
                        <div class="flex-grow mb-4">
                            <p class="text-sm text-surface-400 mb-2" set:html={t('agencies.leverage.c4.challenge')}></p>
                            <p class="text-sm text-white" set:html={t('agencies.leverage.c4.solution')}></p>
                        </div>
                        <div class="mt-auto pt-4 border-t border-surface-800 flex items-start">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check-circle.svg"
                                 alt="Checkmark"
                                 class="w-4 h-4 mr-2 filter invert opacity-80 flex-shrink-0 mt-0.5"/>
                            <span class="text-sm font-medium text-white" set:html={t('agencies.leverage.c4.result')}>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA (keep consistent with site) -->
    <!-- CTA Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-8 animate-on-scroll fade-in-up">
                {t('agencies.cta.title')}</h2>
            <div class="flex items-center justify-center gap-x-6 animate-on-scroll fade-in-up delay-100">
                <a href="https://app.firecms.co"
                   class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                    {t('agencies.cta.primary')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-5 w-5 text-white filter invert"/>
                </a>
                <a href="/developers"
                   class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
                    {t('agencies.cta.secondary')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-4 w-4 text-white filter invert"/>
                </a>
            </div>
        </div>
    </section>
</main>

---
import SectionBackgroundAccents from "../SectionBackgroundAccents.astro";
import ScreenshotsMarquee from "../ScreenshotsMarquee.astro";
import ClientLogos from "../ClientLogos.astro";

const { lang, t } = Astro.props;

// Inline SVG icon definitions
const zapIcon = `<svg class="h-10 w-10 mb-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`;
const cloudIcon = `<svg class="h-10 w-10 mb-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" /></svg>`;
const spreadsheetIcon = `<svg class="h-10 w-10 mb-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125v-12.75c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v12.75c0 .621-.504 1.125-1.125 1.125m-17.25 0h17.25m-17.25 0l1.125 1.125c.15.15.313.225.487.225h14.25c.174 0 .337-.075.487-.225l1.125-1.125m-17.25 0h17.25M9 13.125h6M9 16.5h6" /></svg>`;
---

<main>
    <!-- Hero Section -->
    <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24">
      <!-- Background accents and subtle grid -->
      <SectionBackgroundAccents topLine={true} blob={{ position: "top", size: "lg", opacity: 60 }}/>
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -bottom-40 right-1/3 w-[700px] h-[700px] rounded-full bg-blue-500/5 blur-3xl opacity-50"></div>
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:40px_40px] opacity-10"></div>
      </div>

      <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
        <h1 class="mb-6 text-4xl font-medium tracking-tight md:text-5xl lg:text-6xl text-white font-sans" set:html={t('startups.hero.title')}></h1>
        <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-48" set:html={t('startups.hero.subtitle')}></p>
        <a href="https://app.firecms.co" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark transition-all duration-200 ease-in-out btn-glow">
          {t('startups.hero.cta')}
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>

    <section class="relative isolate bg-black py-16">
        <div class="mx-auto max-w-7xl px-8 lg:px-12">
            <h2 class="text-center text-lg font-semibold leading-8 text-surface-400">
                {t('startups.trusted')}
            </h2>
            <div class="mx-auto mt-4 mb-8">
                <ClientLogos filter="startups"/>
            </div>
        </div>
        <SectionBackgroundAccents bottomLine={true}/>
    </section>

    <!-- Problem / Solution Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('startups.problem.title')}</h2>
          <p class="mt-6 text-lg leading-8 text-surface-400">{t('startups.problem.desc')}</p>
        </div>

        <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800">
          <img src="/img/users_table.png"
               alt="Screenshot of FireCMS Admin Panel managing User Data"
               class="w-full h-auto"/>
        </div>

      </div>
    </section>

    <!-- "Built for Velocity" Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('startups.velocity.title')}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <Fragment set:html={zapIcon} />
            <h3 class="text-xl font-semibold mb-2 text-white">{t('startups.velocity.setup.title')}</h3>
            <p class="text-surface-400 text-sm leading-relaxed">{t('startups.velocity.setup.desc')}</p>
          </div>
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <Fragment set:html={cloudIcon} />
            <h3 class="text-xl font-semibold mb-2 text-white">{t('startups.velocity.launch.title')}</h3>
            <p class="text-surface-400 text-sm leading-relaxed">{t('startups.velocity.launch.desc')}</p>
          </div>
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <Fragment set:html={spreadsheetIcon} />
            <h3 class="text-xl font-semibold mb-2 text-white">{t('startups.velocity.empower.title')}</h3>
            <p class="text-surface-400 text-sm leading-relaxed">{t('startups.velocity.empower.desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section id="testimonials" class="relative isolate bg-black py-24 sm:py-32 scroll-mt-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('startups.testimonials.title')}</h2>
        </div>
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-2">
          <!-- Example Quote 3: EasyHome -->
          <figure class="text-center">
            <blockquote class="text-xl leading-8 text-surface-300">
              <p>{t('startups.testimonials.q1')}</p>
            </blockquote>
            <figcaption class="mt-8 flex items-center justify-center gap-x-4">
              <img class="h-10 w-10 rounded-full bg-surface-800 object-cover" src="/img/avatars/john.avif" alt="John Coppa"/>
              <div class="text-sm leading-6">
                <div class="font-semibold text-white">{t('startups.testimonials.q1.author')}</div>
                <div class="text-surface-400">{t('startups.testimonials.q1.role')}</div>
              </div>
            </figcaption>
          </figure>

          <!-- Example Quote 4: OikosBrain -->
          <figure class="text-center">
            <blockquote class="text-xl leading-8 text-surface-300">
              <p>{t('startups.testimonials.q2')}</p>
            </blockquote>
            <figcaption class="mt-8 flex items-center justify-center gap-x-4">
              <img class="h-10 w-10 rounded-full bg-surface-800 object-cover" src="/img/avatars/manuel.avif" alt="Manuel Pinilla"/>
              <div class="text-sm leading-6">
                <div class="font-semibold text-white">{t('startups.testimonials.q2.author')}</div>
                <div class="text-surface-400">{t('startups.testimonials.q2.role')}</div>
              </div>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Path to Scale Section -->
    <section class="bg-black py-16 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-3xl text-center">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">{t('startups.scale.title')}</h2>
                <p class="text-lg text-surface-400 mb-8">{t('startups.scale.desc')}</p>
                <a href="/pricing"
                   class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-800 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-700 transition-all duration-200 ease-in-out">
                    {t('startups.scale.cta')}
                </a>
            </div>
            <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800 mt-12">
                <video
                        class="w-full h-auto"
                        loop
                        autoplay
                        muted
                        playsinline>
                    <source src="/img/schema_editor.webm" type="video/webm"/>
                </video>
            </div>
        </div>
    </section>

    <!-- Startup-Friendly Features Section -->
    <section class="bg-black py-16 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-3xl text-center mb-16">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('startups.features.title')}</h2>
                <p class="mt-6 text-lg leading-8 text-surface-400">{t('startups.features.subtitle')}</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/database.svg" alt="Firebase/MongoDB Native" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f1.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f1.desc')}</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cloud-off.svg" alt="Zero Server Management" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f2.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f2.desc')}</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/edit.svg" alt="Schema Editor & Inference" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f3.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f3.desc')}</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-input.svg" alt="Powerful Editing Tools" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f4.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f4.desc')}</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg" alt="Role-Based Access Control" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f5.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f5.desc')}</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4 rounded-lg bg-surface-900/50 p-4 ring-1 ring-inset ring-surface-800 p-8">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/puzzle.svg" alt="Flexible Customization" class="h-6 w-6 filter invert mt-1"/>
                    <div>
                        <h3 class="font-semibold text-white">{t('startups.features.f6.title')}</h3>
                        <p class="text-sm text-surface-400">{t('startups.features.f6.desc')}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="relative bg-black text-surface-200 py-16">
        <ScreenshotsMarquee/>
    </div>

    <!-- More Than Just a CMS Section -->
    <section class="bg-black py-16 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-8 items-start">
                <div>
                    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mb-6">{t('startups.more.title')}</h2>
                    <p class="text-xl text-surface-400 mb-8">
                        {t('startups.more.desc')}
                    </p>
                </div>
                <ul class="text-left text-lg space-y-4">
                    <li class="flex items-start">
                        <svg
                             class="w-6 h-6 mr-3 text-primary flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
                        </svg>
                        <span set:html={t('startups.more.l1')}></span>
                    </li>
                    <li class="flex items-start">
                        <svg
                             class="w-6 h-6 mr-3 text-primary flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span set:html={t('startups.more.l2')}></span>
                    </li>
                    <li class="flex items-start">
                        <svg
                             class="w-6 h-6 mr-3 text-primary flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <span set:html={t('startups.more.l3')}></span>
                    </li>
                    <li class="flex items-start">
                        <svg
                             class="w-6 h-6 mr-3 text-primary flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <span set:html={t('startups.more.l4')}></span>
                    </li>
                    <li class="flex items-start">
                        <svg
                             class="w-6 h-6 mr-3 text-primary flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.096 2.572-1.065z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span set:html={t('startups.more.l5')}></span>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Built for Pivots Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-8 items-center">
          <div class="lg:order-last self-start">
            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">{t('startups.pivots.title')}</h2>
            <p class="text-lg text-surface-400 mb-8">{t('startups.pivots.desc')}</p>
            <a href="/features" class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-800 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-700 transition-all duration-200 ease-in-out">
              {t('startups.pivots.cta')}
            </a>
          </div>
          <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800">
            <img src="/img/widgets.png" alt="FireCMS Widgets" class="w-full h-auto"/>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="bg-black py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-8">{t('startups.cta.title')}</h2>
            <div class="flex items-center justify-center gap-x-6">
                <a href="https://app.firecms.co"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark transition-all duration-200 ease-in-out btn-glow">
                    {t('startups.cta.trial')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-5 w-5 text-white filter invert"/>
                </a>
                <a href="/contact"
                   class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
                    {t('startups.cta.sales')}
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-4 w-4 text-white filter invert"/>
                </a>
            </div>
        </div>
    </section>

  </main>

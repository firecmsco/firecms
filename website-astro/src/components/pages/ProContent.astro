---
// src/components/pages/ProContent.astro
import SectionBackgroundAccents from "../SectionBackgroundAccents.astro";
import { useTranslatedPath } from "../../i18n/utils";

const { lang, t } = Astro.props;
const tp = useTranslatedPath(lang as any);
---

<main class="flex-grow bg-black text-white overflow-hidden">
    <!-- Hero Section -->
    <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24 animate-on-scroll fade-in">
        <!-- Background accents and subtle grid -->
        <SectionBackgroundAccents topLine={true} blob={{ position: "top", size: "lg", opacity: 60 }}/>
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute -bottom-40 right-1/3 w-[700px] h-[700px] rounded-full bg-blue-500/5 blur-3xl opacity-50"></div>
            <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:40px_40px] opacity-10"></div>
        </div>

        <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
            <div class="inline-flex items-center py-1.5 px-3 mb-6 sm:mb-7 text-sm rounded-full bg-yellow-400/10 text-yellow-400 ring-1 ring-inset ring-yellow-400/20 mx-auto animate-on-scroll fade-in-up" role="status">
                <span class="text-sm font-medium">{t('pro.hero.badge')}</span>
            </div>
            <h1 class="mb-6 text-4xl font-medium tracking-tight md:text-5xl lg:text-6xl text-white font-sans animate-on-scroll fade-in-up delay-100">
                {t('pro.hero.title')}
            </h1>
            <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-48 max-w-4xl mx-auto animate-on-scroll fade-in-up delay-200">
                {t('pro.hero.subtitle')}
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-on-scroll fade-in-up delay-300">
                <a href="https://app.firecms.co/subscriptions" target="_blank" rel="noopener noreferrer"
                   class="w-full sm:w-auto inline-flex items-center justify-center gap-x-2 rounded-md bg-yellow-400 px-6 py-3 text-base font-semibold text-black shadow-sm hover:bg-yellow-300 transition-all duration-200 ease-in-out btn-glow">
                    {t('pro.hero.cta.buy')}
                    <svg class="h-5 w-5 text-black" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                </a>
                <a href={tp("/docs/pro/licensing")}
                   class="w-full sm:w-auto inline-flex items-center justify-center gap-x-2 rounded-md border border-surface-700 bg-white/5 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-white/10 transition-all duration-200">
                    {t('pro.hero.cta.docs')}
                </a>
            </div>
        </div>
    </section>

    <!-- Visual Showcase / Key Features -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-3xl text-center mb-20 animate-on-scroll fade-in-up">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">Everything You Need for Enterprise Custom Builds</h2>
                <p class="mt-4 text-lg text-surface-400">Unlock pre-built widgets, developer interfaces, and administrative dashboards that save months of engineering time.</p>
            </div>

            <!-- Feature 1 -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-16 border-b border-surface-800 animate-on-scroll fade-in-up">
                <div class="lg:col-span-5 space-y-6">
                    <div class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center text-yellow-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l8.904-4.473L21 9l-3.482-3.482-7.705 7.705zm0 0L3 9h4.125m2.778 0H14m-2.677 3.323L9 18.125" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-white">Visual Schema Builder</h3>
                    <p class="text-surface-400 leading-relaxed">
                        Design and modify database models dynamically inside a visual editor. Let FireCMS automatically infer schema structures directly from your existing collections, and publish schemas instantly with no code deployments needed.
                    </p>
                </div>
                <div class="lg:col-span-7">
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800 bg-surface-900/50 p-2">
                        <img src="/img/toleroo_recipe.webp" alt="Visual Schema Builder" class="rounded-xl w-full shadow-2xl" />
                    </div>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-16 border-b border-surface-800 animate-on-scroll fade-in-up delay-100">
                <div class="lg:col-span-7 order-last lg:order-first">
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800 bg-surface-900/50 p-2">
                        <img src="/img/prime_um.png" alt="User Management UI" class="rounded-xl w-full shadow-2xl" />
                    </div>
                </div>
                <div class="lg:col-span-5 space-y-6">
                    <div class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center text-yellow-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.109A11.386 11.386 0 0110.089 21c-2.316 0-4.48-.69-6.3-1.872v-.109A4.125 4.125 0 018.125 15c1.472 0 2.822.384 4.01 1.058m1.785-3.07C14.417 12.083 14.7 11.07 14.7 10c0-2.315-1.042-4.385-2.7-5.748M14.7 10a4.7 4.7 0 01-9.4 0M10 20a1 1 0 010-2v-1.05M3 18.75V21" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-white">Pre-built User Management & Roles</h3>
                    <p class="text-surface-400 leading-relaxed">
                        Control who can access, edit, or delete collections with fine-grained permissions. Establish role-based access control (RBAC) rules visually and manage all team members in a secure dashboard.
                    </p>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-16 border-b border-surface-800 animate-on-scroll fade-in-up">
                <div class="lg:col-span-5 space-y-6">
                    <div class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center text-yellow-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-white">Advanced Import & Export</h3>
                    <p class="text-surface-400 leading-relaxed">
                        Say goodbye to custom database migration scripts. Bulk-upload datasets from CSV, JSON, or Excel sheets. Map CSV columns to complex properties (like references, array fields, or nested maps) with live validation.
                    </p>
                </div>
                <div class="lg:col-span-7">
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800 bg-surface-900/50 p-2">
                        <img src="/img/import_mapping.webp" alt="Import Data Visual Mapping" class="rounded-xl w-full shadow-2xl" />
                    </div>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-16 border-b border-surface-800 animate-on-scroll fade-in-up delay-100">
                <div class="lg:col-span-7 order-last lg:order-first">
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-800 bg-surface-900/50 p-2">
                        <img src="/img/history.png" alt="Entity History & Audit Trail" class="rounded-xl w-full shadow-2xl" />
                    </div>
                </div>
                <div class="lg:col-span-5 space-y-6">
                    <div class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center text-yellow-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-white">Entity Revisions & Audit Log</h3>
                    <p class="text-surface-400 leading-relaxed">
                        Track every write operation to your Firestore database. Know exactly who made changes, what values were modified, and revert to previous versions easily using standard document histories.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Next.js Integration Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center animate-on-scroll fade-in-up">
                <div class="space-y-6">
                    <div class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center text-yellow-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" />
                        </svg>
                    </div>
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">Seamless Next.js Integration</h2>
                    <p class="text-surface-400 leading-relaxed">
                        Deploy your back-office directly inside your Next.js project. Use Next App Router, dynamic routes, and server-side components next to your CMS screens. Maintain complete flexibility using standard React dependencies.
                    </p>
                    <ul class="space-y-3 text-surface-300">
                        <li class="flex items-center gap-3">
                            <svg class="h-5 w-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                            </svg>
                            Perfect for Next.js App Router & Pages Router
                        </li>
                        <li class="flex items-center gap-3">
                            <svg class="h-5 w-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                            </svg>
                            Keep configurations version-controlled in Git
                        </li>
                        <li class="flex items-center gap-3">
                            <svg class="h-5 w-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                            </svg>
                            Direct React router binding
                        </li>
                    </ul>
                </div>
                <div class="relative bg-surface-900/40 rounded-2xl border border-surface-800 p-6 font-mono text-sm shadow-xl">
                    <div class="flex items-center justify-between border-b border-surface-800 pb-3 mb-4">
                        <span class="text-xs text-surface-500 font-medium">app/cms/page.tsx</span>
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-500/30"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500/30"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500/30"></div>
                        </div>
                    </div>
                    <pre class="overflow-x-auto text-surface-200" set:html={`<code><span class="text-blue-400">"use client"</span>;

<span class="text-purple-400">import</span> { FireCMS } <span class="text-purple-400">from</span> <span class="text-green-300">"@firecms/core"</span>;
<span class="text-purple-400">import</span> { useFirebaseCMSApp } <span class="text-purple-400">from</span> <span class="text-green-300">"@firecms/firebase"</span>;

<span class="text-purple-400">export default function</span> <span class="text-blue-300">CMSPage</span>() {
    <span class="text-purple-400">const</span> cmsApp = <span class="text-blue-300">useFirebaseCMSApp</span>({
        firebaseConfig,
        collections: [productsCollection],
        <span class="text-surface-500">// Unlock premium PRO features</span>
        licenseKey: process.env.NEXT_PUBLIC_LIC_KEY
    });

    <span class="text-purple-400">return</span> &lt;<span class="text-blue-300">FireCMS</span> {...cmsApp} /&gt;;
}</code>`} />
                </div>
            </div>
        </div>
    </section>

    <!-- Absolute Sovereignty / Security Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center animate-on-scroll fade-in-up">
            <div class="mx-auto max-w-3xl">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">Your Data, Your Servers</h2>
                <p class="text-lg text-surface-400 leading-relaxed mb-8">
                    Unlike standard SaaS platforms, FireCMS PRO runs entirely client-side or on your own servers. All write and read operations are sent directly between the browser and your Firestore/MongoDB instance. We never proxy, intercept, or store your database credentials.
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center mt-12">
                    <div class="bg-surface-900/30 rounded-xl border border-surface-800 p-6">
                        <div class="text-3xl font-extrabold text-yellow-400 mb-2">100%</div>
                        <div class="text-sm font-medium text-white">Data Sovereignty</div>
                    </div>
                    <div class="bg-surface-900/30 rounded-xl border border-surface-800 p-6">
                        <div class="text-3xl font-extrabold text-yellow-400 mb-2">Zero</div>
                        <div class="text-sm font-medium text-white">Data Ingestion</div>
                    </div>
                    <div class="bg-surface-900/30 rounded-xl border border-surface-800 p-6">
                        <div class="text-3xl font-extrabold text-yellow-400 mb-2">Direct</div>
                        <div class="text-sm font-medium text-white">Firebase/Atlas SDKs</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA Section -->
    <section class="relative isolate bg-black py-16 sm:py-24">
        <SectionBackgroundAccents topLine={true}/>
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-8 animate-on-scroll fade-in-up">
                Upgrade to FireCMS PRO Today
            </h2>
            <p class="text-lg text-surface-400 max-w-2xl mx-auto mb-10 animate-on-scroll fade-in-up delay-100">
                Unlock custom authentication, white-labeling, priority support, and advanced administration views.
            </p>
            <div class="flex items-center justify-center gap-x-6 animate-on-scroll fade-in-up delay-200">
                <a href="https://app.firecms.co/subscriptions" target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-x-2 rounded-md bg-yellow-400 px-6 py-3 text-base font-semibold text-black shadow-sm hover:bg-yellow-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-yellow-400 transition-all duration-200 ease-in-out btn-glow">
                    Buy PRO License
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-5 w-5 text-black"/>
                </a>
                <a href={tp("/pricing")}
                   class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
                    Compare Plans
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                         class="h-4 w-4 text-white filter invert"/>
                </a>
            </div>
        </div>
    </section>
</main>

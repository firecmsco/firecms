---
// src/components/pages/AboutContent.astro
import SectionBackgroundAccents from "../SectionBackgroundAccents.astro";

const { lang, t } = Astro.props;
---

<main>
    <!-- Hero Section -->
    <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24">
      <!-- Background accents and subtle grid -->
      <SectionBackgroundAccents topLine={true} blob={{ position: "top", size: "lg", opacity: 60 }}>
        <div class="absolute -bottom-40 right-1/3 w-[700px] h-[700px] rounded-full bg-blue-500/5 blur-3xl opacity-50"></div>
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:40px_40px] opacity-10"></div>
    </SectionBackgroundAccents>

      <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
        <h1 class="mb-6 text-4xl font-medium tracking-tight md:text-5xl lg:text-6xl text-white font-sans">
          {t('about.hero.title')}
        </h1>
        <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-48" set:html={t('about.hero.subtitle')}></p>
      </div>
    </section>

    <!-- Our Story Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-4xl px-6 lg:px-8">
        <div class="mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-8">{t('about.story.title')}</h2>
          <div class="prose prose-lg prose-invert max-w-none">
            <p class="text-lg text-surface-300 leading-relaxed mb-6" set:html={t('about.story.p1')}></p>
            <p class="text-lg text-surface-300 leading-relaxed mb-6" set:html={t('about.story.p2')}></p>
            <p class="text-lg text-surface-300 leading-relaxed" set:html={t('about.story.p3')}></p>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission & Values Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('about.values.title')}</h2>
        </div>
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
          <!-- Value 1 -->
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <div class="flex items-center gap-4 mb-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              </div>
            </div>
            <h3 class="text-2xl font-semibold text-white mb-4">{t('about.values.v1.title')}</h3>
            <p class="text-surface-400">{t('about.values.v1.desc')}</p>
          </div>
          <!-- Value 2 -->
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <div class="flex items-center gap-4 mb-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
            </div>
            <h3 class="text-2xl font-semibold text-white mb-4">{t('about.values.v2.title')}</h3>
            <p class="text-surface-400">{t('about.values.v2.desc')}</p>
          </div>
          <!-- Value 3 -->
          <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
            <div class="flex items-center gap-4 mb-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
            </div>
            <h3 class="text-2xl font-semibold text-white mb-4">{t('about.values.v3.title')}</h3>
            <p class="text-surface-400">{t('about.values.v3.desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('about.stats.title')}</h2>
        </div>
        <div class="grid grid-cols-1 gap-8 grid-cols-3">
          <div class="text-center">
            <div class="text-5xl font-medium text-primary mb-2" set:html={t('about.stats.s1.value')}></div>
            <div class="text-surface-400">{t('about.stats.s1.label')}</div>
          </div>
          <div class="text-center">
            <div class="text-5xl font-medium text-primary mb-2" set:html={t('about.stats.s2.value')}></div>
            <div class="text-surface-400">{t('about.stats.s2.label')}</div>
          </div>
          <div class="text-center">
            <div class="text-5xl font-medium text-primary mb-2" set:html={t('about.stats.s3.value')}></div>
            <div class="text-surface-400">{t('about.stats.s3.label')}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Join Us Section -->
    <section class="bg-black py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">{t('about.join.title')}</h2>
        <p class="text-lg text-surface-400 mb-8 max-w-2xl mx-auto">{t('about.join.subtitle')}</p>
        <div class="flex items-center justify-center gap-x-6">
          <a href="https://github.com/firecmsco/firecms"
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            {t('about.join.github')}
          </a>
          <a href="https://discord.gg/fxy7xsQm3m"
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
            {t('about.join.discord')}
            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt="" class="h-4 w-4 text-white filter invert" />
          </a>
        </div>
      </div>
    </section>
  </main>

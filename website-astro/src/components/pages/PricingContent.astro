<script>
    // Currency toggle functionality
    function initializeCurrencyToggle() {
        const eurBtn = document.getElementById("currency-eur");
        const usdBtn = document.getElementById("currency-usd");
        const cloudPrice = document.getElementById("cloud-price");
        const proPrice = document.getElementById("pro-price");

        function updateCurrency(currency: string) {
            if (!eurBtn || !usdBtn) return;
            if (currency === "eur") {
                eurBtn.setAttribute("aria-pressed", "true");
                eurBtn.classList.add("text-surface-800", "bg-surface-200", "border-surface-300");
                eurBtn.classList.remove("text-surface-500", "hover:text-surface-700");

                usdBtn.setAttribute("aria-pressed", "false");
                usdBtn.classList.remove("text-surface-800", "bg-surface-200", "border-surface-300");
                usdBtn.classList.add("text-surface-500", "hover:text-surface-700");

                if (cloudPrice) cloudPrice.textContent = cloudPrice.dataset.eur || "€9.99";
                if (proPrice) proPrice.textContent = proPrice.dataset.eur || "€149.99";
            } else {
                usdBtn.setAttribute("aria-pressed", "true");
                usdBtn.classList.add("text-surface-800", "bg-surface-200", "border-surface-300");
                usdBtn.classList.remove("text-surface-500", "hover:text-surface-700");

                eurBtn.setAttribute("aria-pressed", "false");
                eurBtn.classList.remove("text-surface-800", "bg-surface-200", "border-surface-300");
                eurBtn.classList.add("text-surface-500", "hover:text-surface-700");

                if (cloudPrice) cloudPrice.textContent = cloudPrice.dataset.usd || "$11.99";
                if (proPrice) proPrice.textContent = proPrice.dataset.usd || "$199.99";
            }
        }

        if (eurBtn && usdBtn) {
            eurBtn.addEventListener("click", () => updateCurrency("eur"));
            usdBtn.addEventListener("click", () => updateCurrency("usd"));
        }
    }

    document.addEventListener("astro:page-load", initializeCurrencyToggle);
    initializeCurrencyToggle(); // Also run on initial load
</script>

---
import SectionBackgroundAccents from "../SectionBackgroundAccents.astro";

const { lang, t } = Astro.props;
---
<main>
        {/* Hero Section */}
        <section
                class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24">
            <!-- Background accents and subtle grid -->
            <div class="pointer-events-none absolute inset-0 -z-10">
                <div class="absolute -bottom-40 right-1/3 w-[700px] h-[700px] rounded-full bg-blue-500/5 blur-3xl opacity-50"></div>
                <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:40px_40px] opacity-10"></div>
            </div>

            <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
                <h1 class="mb-8 text-5xl font-extrabold tracking-tight leading-none md:text-6xl text-white font-sans">
                    {t('pricing.title')}
                </h1>
                <p class="mb-10 text-lg leading-8 text-surface-300 lg:text-xl sm:px-16 xl:px-48">
                    {t('pricing.subtitle')}
                </p>
                <div class="flex justify-center">
                    <a href="https://calendar.app.google/QipmvFoUznse8KnNA"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="inline-flex items-center gap-2 text-sm text-surface-400 hover:text-primary transition-colors group">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                        </svg>
                        <span class="group-hover:underline">{t('pricing.help')}</span>
                    </a>
                </div>
            </div>
            <SectionBackgroundAccents bottomLine={true}/>
        </section>

        {/* Main Pricing Section - No Toggle, Grid Layout */}
        <section class="relative isolate bg-black py-16 sm:py-24">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                {/* Currency Toggle */}
                <div class="mb-10 flex justify-center w-full">
                    <div class="flex items-center gap-2 text-xs md:text-sm text-surface-500">
                        <div class="inline-flex items-center gap-1">
                            <button id="currency-eur" aria-pressed="true"
                                    class="cursor-pointer px-2 py-0.5 rounded font-medium transition-colors text-surface-800 bg-surface-200 border border-surface-300">
                                EUR €
                            </button>
                            <span class="text-surface-400">/</span>
                            <button id="currency-usd" aria-pressed="false"
                                    class="cursor-pointer px-2 py-0.5 rounded font-medium transition-colors text-surface-500 hover:text-surface-700">
                                USD $
                            </button>
                        </div>
                    </div>
                </div>

                {/* --- Pricing Grid --- */}
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">

                    {/* Column 1: Community (Self-Hosted FREE) - Always Visible */}
                    <div class="relative flex flex-col rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
                        <div class="absolute top-0 right-0 m-4 rounded-full bg-green-500/10 px-3 py-1 text-xs font-semibold text-green-400">
                            {t('pricing.community.badge')}
                        </div>
                        <h3 class="text-2xl font-semibold leading-7 text-white">{t('pricing.community.title')}</h3>
                        <p class="mt-4 text-base font-semibold leading-7 text-surface-400 h-7">&nbsp;</p>
                        <p class="flex items-baseline gap-x-2">
                            <span class="text-4xl font-bold tracking-tight text-white">{t('pricing.community.price')}</span>
                            <span class="text-base font-semibold leading-7 text-surface-400">{t('pricing.community.period')}</span>
                        </p>
                        <p class="mt-6 text-base leading-7 text-surface-300 h-16">{t('pricing.community.desc')}</p>
                        <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-surface-300 xl:mt-10">
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-green-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.community.f1')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-green-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.community.f2')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-green-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.community.f3')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-green-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.community.f4')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-green-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.community.f5')}
                            </li>
                        </ul>
                        <div class="mt-8 flex-grow flex flex-col justify-end"> {/* Use flex-grow and justify-end */}
                            <p class="text-sm text-surface-400 mb-2">{t('pricing.community.getStarted')}</p>
                            <div class="bg-surface-900 rounded-lg p-3 font-mono text-sm text-surface-300 ring-1 ring-surface-700/50 mb-4">
                                npx create-firecms-app
                            </div>
                            <a href="/developers" aria-describedby="tier-community"
                               class="block rounded-md border border-surface-700 bg-transparent px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-surface-800 focus-visible:outline-surface-700 transition-colors duration-200">
                                {t('pricing.community.cta')}
                            </a>
                        </div>
                    </div>

                    {/* Column 2: Cloud Plus (Trial -> Paid) */}
                    <div class="relative flex flex-col rounded-2xl bg-surface-900/50 p-8 ring-2 ring-inset ring-primary"> {/* Highlighted */}
                        <div class="absolute top-0 right-0 m-4 rounded-full bg-primary/20 px-3 py-1 text-xs font-semibold text-primary">
                            {t('pricing.cloud.badge')}
                        </div>
                        <h3 class="text-2xl font-semibold leading-7 text-white">{t('pricing.cloud.title')}</h3>
                        <p class="mt-4 text-base font-semibold leading-7 text-surface-400">{t('pricing.cloud.trial')}</p>
                        <p class="flex items-baseline gap-x-2">
                            <span class="text-4xl font-bold tracking-tight text-white" id="cloud-price" data-eur="€9.99"
                                  data-usd="$11.99">€9.99</span>
                            <span class="text-base font-semibold leading-7 text-surface-400">{t('pricing.cloud.period')}</span>
                        </p>
                        <p class="mt-6 text-base leading-7 text-surface-300 h-16">{t('pricing.cloud.desc')}</p>
                        <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-surface-300 xl:mt-10">
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f1')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f2')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f3')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f4')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f5')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f6')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f7')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-primary">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.cloud.f8')}
                            </li>
                        </ul>
                        <a href="https://app.firecms.co" target="_blank" rel="noopener noreferrer"
                           aria-describedby="tier-plus"
                            class="mt-8 block rounded-md bg-primary px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-primary transition-colors duration-200 btn-glow flex-grow flex flex-col justify-end"
                            data-track
                            id="pricing-cloud-trial"> {/* Use flex-grow and justify-end */}
                            {t('pricing.cloud.cta')}
                        </a>
                    </div>

                    {/* Column 3: PRO (Self-Hosted PAID) */}
                    <div class="relative flex flex-col rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
                        <div class="absolute top-0 right-0 m-4 rounded-full bg-yellow-400/20 px-3 py-1 text-xs font-semibold text-yellow-400">
                            {t('pricing.pro.badge')}
                        </div>
                        <h3 class="text-2xl font-semibold leading-7 text-white">{t('pricing.pro.title')}</h3>
                        <p class="mt-4 text-base font-semibold leading-7 text-surface-400 h-7">&nbsp;</p>
                        <p class="flex items-baseline gap-x-2">
                            <span class="text-4xl font-bold tracking-tight text-white" id="pro-price" data-eur="€149.99"
                                  data-usd="$199.99">€149.99</span>
                            <span class="text-base font-semibold leading-7 text-surface-400">{t('pricing.pro.period')}</span>
                        </p>
                        <p class="mt-6 text-base leading-7 text-surface-300 h-16">{t('pricing.pro.desc')}</p>
                        <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-surface-300 xl:mt-10">
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f1')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f2')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f3')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f4')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f5')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f6')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f7')}
                            </li>
                            <li class="flex gap-x-3 items-center">
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                     class="h-6 w-5 flex-none text-yellow-400">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4.5 12.75l6 6 9-13.5"></path>
                                </svg>
                                {t('pricing.pro.f8')}
                            </li>
                        </ul>
                        <a href="/pro" aria-describedby="tier-pro"
                           data-track
                           id="pricing-pro-license"
                           class="mt-8 block rounded-md bg-white/10 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-white/20 focus-visible:outline-white transition-colors duration-200 flex-grow flex flex-col justify-end"> {/* Use flex-grow and justify-end */}
                            {t('pricing.pro.cta')}
                        </a>
                    </div>

                </div>

                {/* --- Enterprise Section (Below Grid) --- */}
                <div class="mt-16 rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800 lg:col-span-3">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            <h3 class="text-2xl font-semibold leading-7 text-white">{t('pricing.enterprise.title')}</h3>
                            <p class="mt-2 text-base leading-7 text-surface-300">{t('pricing.enterprise.desc')}</p>
                        </div>
                        <a href="/contact"
                           data-track
                           id="pricing-contact-sales"
                           class="flex-shrink-0 rounded-md border border-surface-700 bg-surface-900/50 px-6 py-3 text-center text-sm font-semibold text-white shadow-sm hover:bg-surface-800 focus-visible:outline-surface-700 transition-colors duration-200">
                            {t('pricing.enterprise.cta')}
                        </a>
                    </div>
                </div>

                <div class="mt-16 text-center">
                    <a href="/compare"
                       class="text-base font-semibold leading-6 text-primary-light hover:text-primary transition-colors">
                        {t('pricing.compare')}
                    </a>
                </div>

            </div>
        </section>

        <section class="relative isolate bg-black py-32 sm:py-48">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-3xl">
                    <figure>
                        <blockquote class="text-2xl sm:text-3xl leading-snug text-white tracking-tight">
                            {t('pricing.quote')}
                        </blockquote>
                        <figcaption class="mt-6 flex items-center gap-x-4">
                            <img class="h-12 w-12 rounded-full bg-surface-800 object-cover" src="/img/avatars/viktor.jpeg"
                                 alt="Viktor Vinnk"/>
                            <div class="text-sm leading-6">
                                <div class="font-semibold text-white">{t('pricing.quote.author')}</div>
                                <div class="text-surface-400">{t('pricing.quote.role')}</div>
                            </div>
                        </figcaption>
                    </figure>
                </div>
                <div class="mt-16 text-center">
                    <a href="/why-firecms"
                       class="text-base font-semibold leading-6 text-primary-light hover:text-primary transition-colors">
                        {t('pricing.why')} <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
            <SectionBackgroundAccents bottomLine={true}/>
        </section>

        {/* Book a Call CTA Section */}
        <section class="bg-black py-16 sm:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="relative overflow-hidden rounded-2xl bg-surface-900/50 p-10 md:p-12 text-center ring-1 ring-inset ring-surface-800">
                    <div class="relative z-10">
                        <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 mb-6">
                            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                            </svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{t('pricing.help.title')}</h2>
                        <p class="text-lg text-surface-400 mb-8 max-w-2xl mx-auto">{t('pricing.help.desc')}</p>
                        <a href="https://calendar.app.google/QipmvFoUznse8KnNA"
                           target="_blank"
                            rel="noopener noreferrer"
                            data-track
                            id="pricing-schedule-call"
                            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark transition-all duration-200">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                            </svg>
                            {t('pricing.help.cta')}
                        </a>
                    </div>
                </div>
            </div>
        </section>


        {/* FAQ Section */}
        <section class="bg-black py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-4xl text-center">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">{t('pricing.faq.title')}</h2>
                    {/* <p class="mt-4 text-lg leading-8 text-surface-400">...</p> */}
                </div>
                <div class="mt-16 flow-root">
                    <div class="-my-8 divide-y divide-surface-800">
                        <details class="py-8 group" open>
                            <summary class="flex cursor-pointer items-center justify-between text-left">
                                <h3 class="text-base font-semibold leading-7 text-white">{t('pricing.faq.q1.q')}</h3>
                                <span class="ml-6 flex h-7 items-center">

                                                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20 flex-shrink-0">
                                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/server.svg"
                                                         alt="" class="h-5 w-5 filter invert"/>
                                                </div>
                                                <div>
                                                    <div class="text-lg font-semibold text-white mb-2">Self-host Rebase
                                                    </div>
                                                    <p class="text-surface-400 text-sm mb-4">Deploy Rebase on your own
                                                        infrastructure. Full control over your data, your deployment,
                                                        and your performance.</p>
                                                    <div class="flex items-center gap-4">
                                                        <a href="/docs"
                                                           class="text-sm font-semibold text-white hover:text-primary transition-colors">Read

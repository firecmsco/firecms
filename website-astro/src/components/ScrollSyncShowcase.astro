&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span> 
&nbsp;&nbsp;&nbsp;&nbsp;&#125;
&nbsp;&nbsp;&#125;
&#125;);
                                            </div>
                                        </div>

                                        <!-- 2. Postgres Database -->
                                        <div class="w-full relative z-10 flex flex-col shadow-2xl shadow-black/80 rounded-xl overflow-hidden hover:scale-[1.02] transition-transform duration-300">
                                            <div class="flex items-center justify-between px-4 py-3 bg-surface-900 border-b border-surface-800">

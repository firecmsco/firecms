<span class="text-primary-light">CREATE TABLE</span> <span class="text-white">"products"</span> (
&nbsp;&nbsp;<span class="text-blue-300">"id"</span> <span class="text-white">uuid PRIMARY KEY NOT NULL</span>,
&nbsp;&nbsp;<span class="text-blue-300">"name"</span> <span class="text-white">text NOT NULL</span>,
&nbsp;&nbsp;<span class="text-blue-300">"category"</span> <span class="text-white">text</span>,
&nbsp;&nbsp;<span class="text-blue-300">"price"</span> <span class="text-white">numeric</span>,
&nbsp;&nbsp;<span class="text-blue-300">"currency"</span> <span class="text-white">text</span>
);
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-span-12 w-full mt-2 relative z-10 flex flex-col shadow-2xl shadow-black/80 rounded-xl overflow-hidden border border-surface-800 bg-surface-950 hover:scale-[1.01] transition-transform duration-300">

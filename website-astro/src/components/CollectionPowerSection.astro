---
import SectionBackgroundAccents from "./SectionBackgroundAccents.astro";

// Code is defined in frontmatter so whitespace is preserved exactly
const codeHtml = `<span class="text-primary-light">import</span> { buildCollection } <span class="text-primary-light">from</span> <span class="text-green-400">"@rebasepro/core"</span>;

<span class="text-primary-light">export const</span> <span class="text-white">products</span> = buildCollection({
  <span class="text-blue-300">name</span>: <span class="text-green-400">"Products"</span>,
  <span class="text-blue-300">properties</span>: {
    <span class="text-blue-300">name</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Name"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>,
      <span class="text-blue-300">validation</span>: { <span class="text-blue-300">required</span>: <span class="text-primary-light">true</span> },
    },
    <span class="text-blue-300">category</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Category"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>,
      <span class="text-blue-300">enum</span>: {
        <span class="text-blue-300">electronics</span>: <span class="text-green-400">"Electronics"</span>,
        <span class="text-blue-300">fashion</span>: <span class="text-green-400">"Fashion"</span>,
        <span class="text-blue-300">home</span>: <span class="text-green-400">"Home &amp; Garden"</span>,
      },
    },
    <span class="text-blue-300">price</span>:     { <span class="text-blue-300">name</span>: <span class="text-green-400">"Price"</span>, <span class="text-blue-300">type</span>: <span class="text-green-400">"number"</span> },
    <span class="text-blue-300">in_stock</span>:  { <span class="text-blue-300">name</span>: <span class="text-green-400">"In Stock"</span>, <span class="text-blue-300">type</span>: <span class="text-green-400">"boolean"</span> },
    <span class="text-blue-300">image_url</span>: { <span class="text-blue-300">name</span>: <span class="text-green-400">"Image"</span>, <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>, <span class="text-blue-300">url</span>: <span class="text-primary-light">true</span> },
  },
});`;
---

<section id="collection-power" class="relative isolate bg-black py-24 sm:py-32 border-t border-surface-800/40 overflow-hidden">
    {/* Layout overhaul applied: BG grid lines removed, sticky positioning removed. */}
    {/* Header — keep centred with a soft max-width just for the text */}
    <div class="mx-auto max-w-2xl text-center px-6 mb-16 animate-on-scroll fade-in-up">
        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-5xl leading-tight">
            One collection.<br/>
            <span class="text-primary subtle-shimmer">Everything generated.</span>
        </h2>
        <p class="mt-6 text-lg text-surface-400">
            Define your data model once in TypeScript. Rebase automatically creates your
            admin UI, forms, database schema, REST &amp; GraphQL APIs, and TypeScript types.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-surface-700 bg-surface-900/60 text-surface-300 text-sm font-medium">
            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/sparkles.svg" alt="" class="h-4 w-4 filter invert opacity-60"/>
            Code as Truth
        </div>
    </div>

    {/*
      ══════════════════════════════════════════════════════════════
      Full-width diagram — no max-w constraint, just side padding
      3 column layout
    */}
    <div id="cp-diagram" class="relative hidden lg:flex items-center justify-center gap-4 xl:gap-6 w-full max-w-[1400px] mx-auto min-h-[600px] my-10 animate-on-scroll fade-in-up delay-100 px-6">

        {/* ── Dynamic SVG connector lines — drawn by client script ── */}
        <svg id="cp-connectors" class="absolute inset-0 w-full h-full pointer-events-none z-10">
        </svg>

        <script>
        (function drawConnectors() {
            function update() {
                const diagram = document.getElementById('cp-diagram');
                const svg = document.getElementById('cp-connectors');
                if (!diagram || !svg) return;

                const codeBlock = diagram.querySelector('#cp-code-block');
                if (!codeBlock) return;

                const cards = diagram.querySelectorAll('[data-card]');
                if (!cards.length) return;

                const dRect = diagram.getBoundingClientRect();
                const cRect = codeBlock.getBoundingClientRect();

                // Code block center relative to diagram
                const cx = cRect.left + cRect.width / 2 - dRect.left;
                const cy = cRect.top + cRect.height / 2 - dRect.top;

                // Clear existing paths
                svg.querySelectorAll('path.connector').forEach(p => p.remove());

                cards.forEach(card => {
                    const r = card.getBoundingClientRect();
                    const cardCx = r.left + r.width / 2 - dRect.left;
                    const cardCy = r.top + r.height / 2 - dRect.top;

                    // Start from code block edge
                    let startX, startY;
                    if (cardCx < cx) {
                        startX = cRect.left - dRect.left;
                        startY = cy + (cardCy - cy) * 0.3;
                    } else {
                        startX = cRect.right - dRect.left;
                        startY = cy + (cardCy - cy) * 0.3;
                    }

                    // End at card edge
                    let endX, endY;
                    if (cardCx < cx) {
                        endX = r.right - dRect.left;
                        endY = cardCy;
                    } else {
                        endX = r.left - dRect.left;
                        endY = cardCy;
                    }

                    // Control point for curve
                    const cpX = (startX + endX) / 2;
                    const cpY = (startY + endY) / 2 + (endY - startY) * 0.15;
                    const d = `M ${startX} ${startY} Q ${cpX} ${cpY}, ${endX} ${endY}`;

                    // Layer 1: wide outer glow
                    const glow2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    glow2.setAttribute('d', d);
                    glow2.setAttribute('fill', 'none');
                    glow2.setAttribute('stroke', 'rgba(217,119,6,0.04)');
                    glow2.setAttribute('stroke-width', '10');
                    glow2.classList.add('connector');
                    svg.appendChild(glow2);

                    // Layer 2: medium glow
                    const glow1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    glow1.setAttribute('d', d);
                    glow1.setAttribute('fill', 'none');
                    glow1.setAttribute('stroke', 'rgba(217,119,6,0.08)');
                    glow1.setAttribute('stroke-width', '4');
                    glow1.classList.add('connector');
                    svg.appendChild(glow1);

                    // Layer 3: core line (matches card border)
                    const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    line.setAttribute('d', d);
                    line.setAttribute('fill', 'none');
                    line.setAttribute('stroke', 'rgba(217,119,6,0.5)');
                    line.setAttribute('stroke-width', '1');
                    line.classList.add('connector');
                    svg.appendChild(line);
                });
            }

            // Run after layout settles
            if (document.readyState === 'complete') {
                setTimeout(update, 100);
            } else {
                window.addEventListener('load', () => setTimeout(update, 100));
            }
            window.addEventListener('resize', update);
        })();
        </script>

        {/* ══════════ LEFT CARDS ══════════ */}
        <div class="flex flex-col items-end justify-center gap-6 flex-1 min-w-0 z-20">
            {/* Admin views — matches real VirtualTable styling */}
            <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl relative z-10 w-[360px] xl:w-[400px] mr-2 xl:mr-4">
                {/* Toolbar — collection name + search + add */}
                <div class="flex items-center justify-between px-3 py-2 border-b border-surface-700/40">
                    <span class="text-sm text-white font-medium">Products</span>
                    <div class="flex items-center gap-1.5">
                        <div class="h-7 bg-surface-800/60 rounded-md px-2.5 flex items-center gap-1.5">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/search.svg" alt="" class="h-3 w-3 filter invert opacity-40"/>
                            <span class="text-[11px] text-surface-500">Search…</span>
                        </div>
                        <div class="w-7 h-7 rounded-md flex items-center justify-center bg-surface-800/60 hover:bg-surface-700/60">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/plus.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                        </div>
                    </div>
                </div>
                {/* Header row — bg-surface-900, no vertical borders, uppercase */}
                <div class="flex text-[10px] font-semibold text-surface-500 tracking-wider uppercase border-b border-surface-700/40 bg-surface-900">
                    <div class="px-3 py-2.5 w-[72px] text-center">ID</div>
                    <div class="px-3 py-2.5 flex-1">Name</div>
                    <div class="px-3 py-2.5 w-[100px]">Category</div>
                    <div class="px-3 py-2.5 w-14 text-right">Price</div>
                    <div class="px-3 py-2.5 w-14 text-center">Stock</div>
                </div>
                {/* Data rows — no vertical borders, horizontal dividers only */}
                {[
                    { id: "x7kQ2p", name: "Wireless Headphones", cat: "Electronics",   catColor: "bg-blue-950 text-blue-300",   price: "€129", stock: true  },
                    { id: "mR9vLw", name: "Silk Scarf",          cat: "Fashion",       catColor: "bg-pink-950 text-pink-300",   price: "€99",  stock: false },
                    { id: "p4tN8x", name: "Mechanical Keyboard", cat: "Electronics",   catColor: "bg-blue-950 text-blue-300",   price: "€149", stock: true  },
                    { id: "b2vF1z", name: "Ceramic Mug",         cat: "Home",          catColor: "bg-green-950 text-green-300", price: "€24",  stock: true  },
                ].map((row) => (
                    <div class="flex text-sm border-b border-surface-800/40 last:border-0 hover:bg-surface-800/30 cursor-pointer">
                        <div class="px-3 py-3 w-[72px] text-surface-500 font-mono text-xs text-center truncate">{row.id}</div>
                        <div class="px-3 py-3 text-surface-200 flex-1 truncate">{row.name}</div>
                        <div class="px-3 py-3 w-[100px]">
                            <span class={`rounded-md px-1.5 py-0.5 text-[10px] font-medium ${row.catColor}`}>{row.cat}</span>
                        </div>
                        <div class="px-3 py-3 text-surface-200 text-right w-14">{row.price}</div>
                        <div class="px-3 py-3 w-14 flex justify-center">
                            {/* Inline boolean switch matching BooleanSwitch */}
                            <div class={`w-7 h-[16px] rounded-full relative flex-shrink-0 ${row.stock ? 'bg-primary' : 'bg-surface-600'}`}>
                                <div class={`absolute top-[2px] w-3 h-3 rounded-full bg-white shadow-sm transition-all ${row.stock ? 'right-[2px]' : 'left-[2px]'}`}></div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            {/* Entity Form — matches real EntityForm styling */}
            <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl w-[320px] xl:w-[350px] mr-6 xl:mr-10">
                {/* Form content — no card header, title inline like real product */}
                <div class="px-5 pt-5 pb-4 space-y-4">
                    {/* Title + sync indicator */}
                    <div class="flex items-center justify-between">
                        <span class="text-base font-medium text-white">Wireless Headphones</span>
                        <span class="inline-flex items-center gap-1 text-[10px] font-medium text-green-400 bg-green-950/60 border border-green-800/40 px-1.5 py-0.5 rounded-full">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check.svg" alt="" class="h-2.5 w-2.5 filter" style="filter: invert(73%) sepia(60%) saturate(500%) hue-rotate(85deg) brightness(95%) contrast(95%)"/>
                            Saved
                        </span>
                    </div>
                    {/* Entity path */}
                    <div class="rounded-md bg-surface-800/40 px-3 py-1.5">
                        <code class="text-[10px] text-surface-500 select-all">products/x7kQ2p</code>
                    </div>

                    {/* Name field — floating label inside fieldBackgroundMixin */}
                    <div class="relative rounded-md bg-surface-800/60 min-h-[48px] flex flex-col justify-center">
                        <span class="absolute top-1.5 left-3 text-[10px] text-primary font-medium">Name <span class="text-red-400">*</span></span>
                        <div class="px-3 pt-6 pb-2 text-sm text-surface-200">Wireless Headphones</div>
                    </div>
                    {/* Category field — select style */}
                    <div class="relative rounded-md bg-surface-800/60 min-h-[48px] flex flex-col justify-center">
                        <span class="absolute top-1.5 left-3 text-[10px] text-surface-400 font-medium">Category</span>
                        <div class="px-3 pt-6 pb-2 flex items-center justify-between">
                            <span class="rounded-md px-1.5 py-0.5 text-[10px] font-medium bg-blue-950 text-blue-300">Electronics</span>
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/chevron-down.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-30"/>
                        </div>
                    </div>
                    {/* Price field */}
                    <div class="relative rounded-md bg-surface-800/60 min-h-[48px] flex flex-col justify-center">
                        <span class="absolute top-1.5 left-3 text-[10px] text-surface-400 font-medium">Price</span>
                        <div class="px-3 pt-6 pb-2 text-sm text-surface-200 flex items-center gap-1">
                            <span class="text-surface-500">€</span> 129
                        </div>
                    </div>
                    {/* Boolean field — BooleanSwitchWithLabel style */}
                    <div class="rounded-md bg-surface-800/60 min-h-[48px] px-4 flex items-center justify-between cursor-pointer">
                        <span class="text-sm text-surface-200">In Stock</span>
                        <div class="w-9 h-5 rounded-full bg-primary relative flex-shrink-0">
                            <div class="absolute right-[3px] top-[3px] w-3.5 h-3.5 rounded-full bg-white shadow-sm"></div>
                        </div>
                    </div>
                    {/* Save button */}
                    <button type="button" class="w-full text-sm py-2.5 rounded-md bg-primary text-white font-semibold hover:bg-primary/90 transition-colors">Save</button>
                </div>
            </div>
        </div>

        {/* ══════════ CENTER: Code block ══════════ */}
        <div class="flex flex-col gap-4 w-[340px] xl:w-[400px] shrink-0 z-20">
            {/* Radial glow behind code block */}
            <div id="cp-code-block" class="relative shadow-[0_0_60px_rgba(217,119,6,0.08)] rounded-xl">
                <div class="absolute -inset-12 rounded-3xl pointer-events-none"
                     style="background: radial-gradient(ellipse at center, rgba(217,119,6,0.08) 0%, rgba(217,119,6,0.03) 50%, transparent 80%);"></div>

                <div class="relative z-10 rounded-xl overflow-hidden ring-1 ring-amber-600/50 shadow-[0_0_15px_rgba(217,119,6,0.25)] bg-surface-950">
                    <div class="flex items-center justify-between px-4 py-3 bg-surface-900 border-b border-surface-800">
                        <div class="flex items-center gap-3">
                            <div class="flex gap-1.5">
                                <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
                            </div>
                            <span class="text-[11px] text-surface-400 font-mono tracking-wider uppercase font-semibold ml-2">App Code</span>
                        </div>
                        <span class="text-[11px] text-surface-500 font-mono">products.ts</span>
                    </div>
                    <pre class="bg-surface-950 px-5 py-5 font-mono text-[12px] leading-relaxed text-surface-300 overflow-x-auto" set:html={codeHtml}></pre>
                </div>
            </div>

            {/* "generates all of the following" */}
            <div class="flex flex-col items-center gap-3">
                <p class="text-xs text-surface-500 font-mono">→ generates all of the following</p>
                <div class="flex flex-wrap justify-center gap-2">
                    {[
                        { icon: "table-2",           label: "Admin views" },
                        { icon: "layout-panel-left", label: "Entity Form" },
                        { icon: "database",          label: "DB Schema" },
                        { icon: "code-2",            label: "Typed SDK" },
                        { icon: "globe",             label: "REST API" },
                        { icon: "git-branch",        label: "GraphQL" },
                    ].map(item => (
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border border-surface-800 bg-surface-900/60 text-surface-400 text-[11px]">
                            <img src={`https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/${item.icon}.svg`} alt="" class="h-3 w-3 filter invert opacity-50"/>
                            {item.label}
                        </span>
                    ))}
                </div>
            </div>
        </div>

        {/* ══════════ RIGHT CARDS ══════════ */}
        <div class="flex flex-col items-start justify-center gap-5 flex-1 min-w-0 z-20">
            {/* DB Schema — offset up */}
            <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl xl:-mt-10 w-[270px] xl:w-[310px] ml-2 xl:ml-6">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/database.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">DB Schema</span>
                    <img src="https://www.postgresql.org/media/img/about/press/elephant.png" class="h-3 opacity-35 grayscale filter brightness-200 ml-auto" alt="postgres"/>
                </div>
                <div class="p-4 font-mono text-[11px] leading-relaxed text-surface-400">
                    <pre set:html={`<span class="text-primary-light">CREATE TABLE</span> <span class="text-white">"products"</span> (
  <span class="text-blue-300">"id"</span>         <span class="text-white">uuid PRIMARY KEY</span>,
  <span class="text-blue-300">"name"</span>       <span class="text-white">text NOT NULL</span>,
  <span class="text-blue-300">"category"</span>   <span class="text-white">text</span>,
  <span class="text-blue-300">"price"</span>      <span class="text-white">numeric(10,2)</span>,
  <span class="text-blue-300">"in_stock"</span>   <span class="text-white">boolean</span>
                 <span class="text-white">DEFAULT false</span>,
  <span class="text-blue-300">"image_url"</span>  <span class="text-white">text</span>,
  <span class="text-blue-300">"created_at"</span> <span class="text-white">timestamptz</span>
                 <span class="text-white">DEFAULT now()</span>
);`}></pre>
                </div>
            </div>

            {/* Typed SDK */}
            <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl w-[350px] xl:w-[420px] ml-4 xl:ml-8 relative z-10">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code-2.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">Typed SDK</span>
                    <span class="ml-auto text-[10px] font-bold text-blue-400 font-mono">TS</span>
                </div>
                <div class="p-4 font-mono text-[11px] leading-relaxed text-surface-400">
                    <pre set:html={`<span class="text-primary-light">import</span> <span class="text-white">{ createClient }</span> <span class="text-primary-light">from</span> <span class="text-green-400">"@rebasepro/client"</span>;

<span class="text-primary-light">const</span> <span class="text-white">client</span> <span class="text-primary-light">=</span> <span class="text-blue-300">createClient</span>();

<span class="text-surface-500">// Fully typed queries</span>
<span class="text-primary-light">const</span> <span class="text-white">{ data }</span> <span class="text-primary-light">=</span> <span class="text-primary-light">await</span> <span class="text-white">client</span>.products.<span class="text-blue-300">list</span>({
  <span class="text-blue-300">where</span>: {
    <span class="text-blue-300">category</span>: <span class="text-green-400">"Electronics"</span>,
    <span class="text-blue-300">in_stock</span>: <span class="text-primary-light">true</span>
  }
});

<span class="text-surface-500">// Type-safe inserts</span>
<span class="text-primary-light">await</span> <span class="text-white">client</span>.products.<span class="text-blue-300">create</span>({
  <span class="text-blue-300">name</span>: <span class="text-green-400">"Camera"</span>,
  <span class="text-blue-300">price</span>: <span class="text-amber-500">299</span>,
  <span class="text-blue-300">category</span>: <span class="text-green-400">"Electronics"</span>
});`}></pre>
                </div>
            </div>

            {/* API Column — REST and GraphQL Side by Side */}
            <div class="flex flex-row gap-4 items-start w-full ml-0 xl:ml-6">
                {/* REST API */}
                <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl w-[185px] xl:w-[200px] shrink-0">
                    <div class="flex items-center gap-2 px-3 py-2.5 border-b border-surface-800 bg-surface-900/60">
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/globe.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                        <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">REST API</span>
                    </div>
                    <div class="divide-y divide-surface-800/50">
                        {[
                            { method: "GET",    color: "bg-blue-950 text-blue-300 border-blue-800/40",       path: "/api/products" },
                            { method: "POST",   color: "bg-green-950 text-green-300 border-green-800/40",    path: "/api/products" },
                            { method: "PATCH",  color: "bg-amber-950 text-amber-300 border-amber-800/40",    path: "/api/products/:id" },
                            { method: "DELETE", color: "bg-red-950 text-red-300 border-red-800/40",          path: "/api/products/:id" },
                        ].map(ep => (
                            <div class="flex items-center justify-between px-3 py-2.5">
                                <span class={`flex-shrink-0 text-[8px] font-bold border px-1.5 py-0.5 rounded font-mono ${ep.color}`}>{ep.method}</span>
                                <span class="font-mono text-[9px] text-surface-400 truncate text-right">{ep.path}</span>
                            </div>
                        ))}
                    </div>
                </div>

                {/* GraphQL */}
                <div data-card class="rounded-xl overflow-hidden ring-1 ring-surface-700 bg-surface-950 shadow-2xl flex-1 max-w-[260px]">
                    <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/git-branch.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                        <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">GraphQL</span>
                        <span class="ml-auto text-[10px] font-bold text-pink-400 font-mono">GQL</span>
                    </div>
                    <div class="p-4 font-mono text-[10px] leading-relaxed text-surface-400 overflow-x-auto">
                        <pre set:html={`<span class="text-primary-light">type</span> <span class="text-white">Product</span> {
  <span class="text-blue-300">id</span>:        <span class="text-green-400">ID!</span>
  <span class="text-blue-300">name</span>:      <span class="text-green-400">String!</span>
  <span class="text-blue-300">category</span>:  <span class="text-green-400">ProductCategory!</span>

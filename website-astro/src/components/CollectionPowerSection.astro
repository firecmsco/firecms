---
import SectionBackgroundAccents from "./SectionBackgroundAccents.astro";

// Code is defined in frontmatter so whitespace is preserved exactly
const codeHtml = `<span class="text-primary-light">import</span> { buildCollection } <span class="text-primary-light">from</span> <span class="text-green-400">"@rebasepro/core"</span>;

<span class="text-primary-light">export const</span> <span class="text-white">products</span> = buildCollection({
  <span class="text-blue-300">name</span>: <span class="text-green-400">"Products"</span>,
  <span class="text-blue-300">properties</span>: {
    <span class="text-blue-300">name</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Name"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>,
      <span class="text-blue-300">validation</span>: { <span class="text-blue-300">required</span>: <span class="text-primary-light">true</span> }
    },
    <span class="text-blue-300">category</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Category"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>,
      <span class="text-blue-300">enum</span>: {
        <span class="text-blue-300">electronics</span>: <span class="text-green-400">"Electronics"</span>,
        <span class="text-blue-300">fashion</span>:     <span class="text-green-400">"Fashion"</span>,
        <span class="text-blue-300">home</span>:        <span class="text-green-400">"Home &amp; Garden"</span>
      }
    },
    <span class="text-blue-300">price</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Price"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"number"</span>
    },
    <span class="text-blue-300">in_stock</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"In Stock"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"boolean"</span>
    },
    <span class="text-blue-300">image_url</span>: {
      <span class="text-blue-300">name</span>: <span class="text-green-400">"Image"</span>,
      <span class="text-blue-300">type</span>: <span class="text-green-400">"string"</span>,
      <span class="text-blue-300">url</span>:  <span class="text-primary-light">true</span>
    }
  }
});`;
---

<section id="collection-power" class="relative isolate bg-black py-24 sm:py-32 border-t border-surface-800/40">
    <SectionBackgroundAccents blob={{ position: "top", size: "lg" }} />

    {/* Header — keep centred with a soft max-width just for the text */}
    <div class="mx-auto max-w-2xl text-center px-6 mb-16 animate-on-scroll fade-in-up">
        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-5xl leading-tight">
            One collection.<br/>
            <span class="text-primary subtle-shimmer">Everything generated.</span>
        </h2>
        <p class="mt-6 text-lg text-surface-400">
            Define your data model once in TypeScript. Rebase automatically creates your
            admin UI, forms, database schema, REST &amp; GraphQL APIs, and TypeScript types.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-surface-700 bg-surface-900/60 text-surface-300 text-sm font-medium">
            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/zap.svg" alt="" class="h-4 w-4 filter invert opacity-60"/>
            Code as Truth
        </div>
    </div>

    {/*
      ══════════════════════════════════════════════════════════════
      Full-width diagram — no max-w constraint, just side padding
      3 columns: [side cards] [code block — sticky] [side cards]
      ══════════════════════════════════════════════════════════════
    */}
    <div id="cp-diagram"
         class="relative hidden lg:grid gap-x-6 xl:gap-x-10 px-6 xl:px-12 animate-on-scroll fade-in-up delay-100"
         style="grid-template-columns: minmax(0,1fr) 400px minmax(0,1fr);">

        {/*
          ──────────────────────────────────────────────────────────
          SVG connector lines
          viewBox "0 0 300 100" → landscape aspect ratio so diagonal
          lines look diagonal, not squashed.

          Approximate column boundaries (% of container → ×3 for 300-unit viewBox):
            Left col  right edge  → 32%   ≈  96
            Code block left edge  → 33.5% ≈ 100
            Code block right edge → 66.5% ≈ 200
            Right col left edge   → 68%   ≈ 204

          Code block center connector: y ≈ 40% → 40 units
          Card centers (y %):
            CMS Table  ≈ 15   Entity Form ≈ 55
            DB Schema  ≈ 13   REST API    ≈ 42   GraphQL ≈ 67
          ──────────────────────────────────────────────────────────
        */}
        <svg
            class="absolute inset-0 w-full h-full pointer-events-none z-10"
            viewBox="0 0 300 100"
            preserveAspectRatio="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
        >
            <defs>
                <filter id="cpGlow" x="-60%" y="-60%" width="220%" height="220%">
                    <feGaussianBlur in="SourceGraphic" stdDeviation="0.8" result="blur"/>
                    <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                </filter>
            </defs>

            {/* ── Wide glow strokes (drawn first, behind) ── */}
            <g stroke="rgb(245 158 11)" fill="none" stroke-width="1.2" opacity="0.06">
                <line x1="100" y1="40" x2="96"  y2="15"/>
                <line x1="100" y1="40" x2="96"  y2="55"/>
                <line x1="200" y1="40" x2="204" y2="13"/>
                <line x1="200" y1="40" x2="204" y2="42"/>
                <line x1="200" y1="40" x2="204" y2="67"/>
            </g>

            {/* ── Main connector lines ── */}
            <g stroke="rgb(245 158 11)" fill="none" stroke-width="0.22" opacity="0.55" filter="url(#cpGlow)">
                {/* Left: code → CMS Table */}
                <line x1="100" y1="40" x2="96"  y2="15"/>
                {/* Left: code → Entity Form */}
                <line x1="100" y1="40" x2="96"  y2="55"/>
                {/* Right: code → DB Schema */}
                <line x1="200" y1="40" x2="204" y2="13"/>
                {/* Right: code → REST API */}
                <line x1="200" y1="40" x2="204" y2="42"/>
                {/* Right: code → GraphQL */}
                <line x1="200" y1="40" x2="204" y2="67"/>
            </g>

            {/* ── Hub dots on code block edges ── */}
            <circle cx="100" cy="40" r="0.9" fill="rgb(245 158 11)" opacity="0.85" filter="url(#cpGlow)"/>
            <circle cx="200" cy="40" r="0.9" fill="rgb(245 158 11)" opacity="0.85" filter="url(#cpGlow)"/>

            {/* ── Card connection dots ── */}
            <g fill="rgb(245 158 11)" opacity="0.6">
                <circle cx="96"  cy="15" r="0.55"/>
                <circle cx="96"  cy="55" r="0.55"/>
                <circle cx="204" cy="13" r="0.55"/>
                <circle cx="204" cy="42" r="0.55"/>
                <circle cx="204" cy="67" r="0.55"/>
            </g>
        </svg>

        {/* ══════════ LEFT COLUMN ══════════ */}
        <div class="flex flex-col gap-4 pt-4 relative z-20">

            {/* CMS Table */}
            <div class="rounded-xl overflow-hidden ring-1 ring-surface-800 bg-surface-950 hover:ring-primary/30 transition-all duration-300">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/table-2.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">CMS Table</span>
                    <span class="ml-auto inline-flex items-center gap-1 text-[10px] font-medium text-green-400 bg-green-950/60 border border-green-800/50 px-1.5 py-0.5 rounded-full">
                        <span class="w-1 h-1 rounded-full bg-green-400 inline-block"></span>Live
                    </span>
                </div>
                <div class="flex items-center justify-between px-4 py-2 border-b border-surface-800/60">
                    <span class="text-xs text-white font-medium">Products <span class="text-surface-500 font-normal ml-1">3 rows</span></span>
                    <div class="flex items-center gap-2">
                        <div class="h-6 bg-surface-900 border border-surface-800 rounded px-2 flex items-center gap-1">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/search.svg" alt="" class="h-3 w-3 filter invert opacity-30"/>
                            <span class="text-[10px] text-surface-600">Search</span>
                        </div>
                        <div class="w-6 h-6 rounded flex items-center justify-center border border-surface-800 bg-surface-900">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/plus.svg" alt="" class="h-3 w-3 filter invert opacity-50"/>
                        </div>
                    </div>
                </div>
                <div class="flex text-[10px] font-semibold text-surface-500 tracking-wider uppercase border-b border-surface-800">
                    <div class="px-3 py-2 border-r border-surface-800 w-7">#</div>
                    <div class="px-3 py-2 border-r border-surface-800 flex-1">Name</div>
                    <div class="px-3 py-2 border-r border-surface-800 w-28">Category</div>
                    <div class="px-3 py-2 border-r border-surface-800 text-right w-14">Price</div>
                    <div class="px-3 py-2 w-12">Stock</div>
                </div>
                {[
                    { name: "Wireless Headphones", cat: "Electronics",   catColor: "bg-blue-950 text-blue-300",   price: "€129", stock: true  },
                    { name: "Silk Scarf",          cat: "Fashion",       catColor: "bg-pink-950 text-pink-300",   price: "€89",  stock: false },
                    { name: "Watering Can",        cat: "Home & Garden", catColor: "bg-green-950 text-green-300", price: "€34",  stock: true  },
                ].map((row, i) => (
                    <div class="flex text-xs border-b border-surface-800/40 last:border-0 hover:bg-surface-900/30 transition-colors">
                        <div class="px-3 py-2.5 border-r border-surface-800/40 text-surface-600 font-mono w-7">{i+1}</div>
                        <div class="px-3 py-2.5 border-r border-surface-800/40 text-surface-200 flex-1 truncate">{row.name}</div>
                        <div class="px-3 py-2.5 border-r border-surface-800/40 w-28">
                            <span class={`rounded px-1.5 py-0.5 text-[10px] font-medium ${row.catColor}`}>{row.cat}</span>
                        </div>
                        <div class="px-3 py-2.5 border-r border-surface-800/40 text-surface-200 text-right w-14">{row.price}</div>
                        <div class="px-3 py-2.5 w-12">
                            <span class={`rounded px-1.5 py-0.5 text-[10px] font-medium ${row.stock ? 'bg-green-950 text-green-300' : 'bg-surface-800 text-surface-500'}`}>
                                {row.stock ? '✓' : '✗'}
                            </span>
                        </div>
                    </div>
                ))}
            </div>

            {/* Entity Form */}
            <div class="rounded-xl overflow-hidden ring-1 ring-surface-800 bg-surface-950 hover:ring-primary/30 transition-all duration-300">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layout-panel-left.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">Entity Form</span>
                </div>
                <div class="p-4 space-y-3">
                    <div class="space-y-1">
                        <label class="text-[10px] font-semibold text-surface-500 uppercase tracking-wider">Name <span class="text-red-400">*</span></label>
                        <div class="rounded-md bg-surface-900 border border-surface-700 px-3 py-2 text-xs text-surface-200">Wireless Headphones</div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-semibold text-surface-500 uppercase tracking-wider">Category</label>
                        <div class="rounded-md bg-surface-900 border border-surface-700 px-3 py-2 flex items-center justify-between">
                            <span class="rounded px-1.5 py-0.5 text-[10px] font-medium bg-blue-950 text-blue-300">Electronics</span>
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/chevron-down.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-30"/>
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-semibold text-surface-500 uppercase tracking-wider">Price</label>
                        <div class="rounded-md bg-surface-900 border border-surface-700 px-3 py-2 text-xs text-surface-200 flex items-center gap-1.5">
                            <span class="text-surface-500">€</span> 129
                        </div>
                    </div>
                    <div class="rounded-md bg-surface-900 border border-surface-700 px-3 py-2 flex items-center gap-3">
                        <div class="w-8 h-4 rounded-full bg-primary relative flex-shrink-0">
                            <div class="absolute right-0.5 top-0.5 w-3 h-3 rounded-full bg-white shadow-sm"></div>
                        </div>
                        <span class="text-xs text-surface-300">In Stock — Yes</span>
                    </div>
                    <button type="button" class="w-full text-xs py-2 rounded-md bg-primary text-white font-semibold">Save entity</button>
                </div>
            </div>

        </div>{/* end left col */}

        {/* ══════════ CENTER: Code block (sticky) ══════════ */}
        <div class="relative z-20">
            <div class="lg:sticky lg:top-28 flex flex-col gap-4">

                {/* Radial glow behind code block */}
                <div class="relative">
                    <div class="absolute -inset-6 rounded-3xl pointer-events-none"
                         style="background: radial-gradient(ellipse at center, rgba(245,158,11,0.06) 0%, transparent 70%);"></div>
                    <div class="absolute -inset-px rounded-xl ring-1 ring-amber-500/15 pointer-events-none"></div>

                    <div class="relative z-10 rounded-xl overflow-hidden ring-1 ring-surface-700/50 bg-surface-950 shadow-2xl shadow-black/80">
                        <div class="flex items-center justify-between px-4 py-3 bg-surface-900 border-b border-surface-800">
                            <div class="flex items-center gap-3">
                                <div class="flex gap-1.5">
                                    <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
                                </div>
                                <span class="text-[11px] text-surface-400 font-mono tracking-wider uppercase font-semibold ml-2">App Code</span>
                            </div>
                            <span class="text-[11px] text-surface-500 font-mono">products.ts</span>
                        </div>
                        <pre class="bg-surface-950 px-5 py-5 font-mono text-[12px] leading-relaxed text-surface-300 overflow-x-auto" set:html={codeHtml}></pre>
                    </div>
                </div>

                {/* "generates all of the following" */}
                <div class="flex flex-col items-center gap-3">
                    <div class="flex items-center gap-3 w-full">
                        <div class="h-px flex-1 bg-surface-800/70"></div>
                        <span class="text-[11px] text-surface-500 font-mono whitespace-nowrap">→ generates all of the following</span>
                        <div class="h-px flex-1 bg-surface-800/70"></div>
                    </div>
                    <div class="flex flex-wrap justify-center gap-2">
                        {[
                            { icon: "table-2",           label: "CMS Table" },
                            { icon: "layout-panel-left", label: "Entity Form" },
                            { icon: "database",          label: "DB Schema" },
                            { icon: "globe",             label: "REST API" },
                            { icon: "git-branch",        label: "GraphQL" },
                        ].map(item => (
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border border-surface-800 bg-surface-900/60 text-surface-400 text-[11px]">
                                <img src={`https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/${item.icon}.svg`} alt="" class="h-3 w-3 filter invert opacity-50"/>
                                {item.label}
                            </span>
                        ))}
                    </div>
                </div>

            </div>
        </div>{/* end center */}

        {/* ══════════ RIGHT COLUMN ══════════ */}
        <div class="flex flex-col gap-4 relative z-20">

            {/* DB Schema */}
            <div class="rounded-xl overflow-hidden ring-1 ring-surface-800 bg-surface-950 hover:ring-primary/30 transition-all duration-300">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/database.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">DB Schema</span>
                    <img src="https://www.postgresql.org/media/img/about/press/elephant.png" class="h-3 opacity-35 grayscale filter brightness-200 ml-auto" alt="postgres"/>
                </div>
                <div class="p-4 font-mono text-[11px] leading-relaxed text-surface-400">
                    <pre set:html={`<span class="text-primary-light">CREATE TABLE</span> <span class="text-white">"products"</span> (
  <span class="text-blue-300">"id"</span>         <span class="text-white">uuid PRIMARY KEY</span>,
  <span class="text-blue-300">"name"</span>       <span class="text-white">text NOT NULL</span>,
  <span class="text-blue-300">"category"</span>   <span class="text-white">text</span>,
  <span class="text-blue-300">"price"</span>      <span class="text-white">numeric(10,2)</span>,
  <span class="text-blue-300">"in_stock"</span>   <span class="text-white">boolean DEFAULT false</span>,
  <span class="text-blue-300">"image_url"</span>  <span class="text-white">text</span>,
  <span class="text-blue-300">"created_at"</span> <span class="text-white">timestamptz DEFAULT now()</span>
);`}></pre>
                </div>
            </div>

            {/* REST API */}
            <div class="rounded-xl overflow-hidden ring-1 ring-surface-800 bg-surface-950 hover:ring-primary/30 transition-all duration-300">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/globe.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">REST API</span>
                </div>
                <div class="divide-y divide-surface-800/50">
                    {[
                        { method: "GET",    color: "bg-blue-950 text-blue-300 border-blue-800/40",       path: "/api/products" },
                        { method: "POST",   color: "bg-green-950 text-green-300 border-green-800/40",    path: "/api/products" },
                        { method: "PATCH",  color: "bg-yellow-950 text-yellow-300 border-yellow-800/40", path: "/api/products/:id" },
                        { method: "DELETE", color: "bg-red-950 text-red-300 border-red-800/40",          path: "/api/products/:id" },
                        { method: "GET",    color: "bg-blue-950 text-blue-300 border-blue-800/40",       path: "/index" },
                    ].map(ep => (
                        <div class="flex items-center gap-2 px-4 py-2.5 hover:bg-surface-900/30 transition-colors">
                            <span class={`flex-shrink-0 text-[9px] font-bold border px-1.5 py-0.5 rounded font-mono ${ep.color}`}>{ep.method}</span>
                            <span class="font-mono text-[11px] text-surface-300 truncate">{ep.path}</span>
                        </div>
                    ))}
                </div>
            </div>

            {/* GraphQL */}
            <div class="rounded-xl overflow-hidden ring-1 ring-surface-800 bg-surface-950 hover:ring-primary/30 transition-all duration-300">
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-surface-800 bg-surface-900/60">
                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/git-branch.svg" alt="" class="h-3.5 w-3.5 filter invert opacity-50"/>
                    <span class="text-[11px] uppercase tracking-wider font-semibold text-surface-400 font-mono">GraphQL</span>
                    <span class="ml-auto text-[10px] font-bold text-pink-400 font-mono">GQL</span>
                </div>
                <div class="p-4 font-mono text-[11px] leading-relaxed text-surface-400">
                    <pre set:html={`<span class="text-primary-light">type</span> <span class="text-white">Product</span> {
  <span class="text-blue-300">id</span>:        <span class="text-green-400">ID!</span>
  <span class="text-blue-300">name</span>:      <span class="text-green-400">String!</span>
  <span class="text-blue-300">category</span>:  <span class="text-green-400">String</span>
  <span class="text-blue-300">price</span>:     <span class="text-green-400">Float</span>
  <span class="text-blue-300">in_stock</span>:  <span class="text-green-400">Boolean</span>
}

<span class="text-primary-light">type</span> <span class="text-white">Query</span> {
  <span class="text-blue-300">products</span>: [<span class="text-green-400">Product!</span>]!
  <span class="text-blue-300">product</span>(<span class="text-blue-300">id</span>: <span class="text-green-400">ID!</span>): <span class="text-green-400">Product</span>
}

<span class="text-primary-light">type</span> <span class="text-white">Mutation</span> {
  <span class="text-blue-300">createProduct</span>(...): <span class="text-green-400">Product!</span>
  <span class="text-blue-300">updateProduct</span>(...): <span class="text-green-400">Product!</span>
  <span class="text-blue-300">deleteProduct</span>(...): <span class="text-green-400">Boolean!</span>
}`}></pre>
                </div>
            </div>

        </div>{/* end right col */}

    </div>{/* end lg grid */}

    {/* Mobile fallback */}
    <div class="lg:hidden px-6 space-y-4 animate-on-scroll fade-in-up delay-100">
        <div class="rounded-xl overflow-hidden ring-1 ring-amber-500/20 bg-surface-950">
            <div class="flex items-center justify-between px-4 py-3 bg-surface-900 border-b border-surface-800">
                <span class="text-[11px] text-surface-400 font-mono uppercase font-semibold">App Code — products.ts</span>
            </div>
            <pre class="bg-surface-950 p-5 font-mono text-[11px] leading-relaxed text-surface-300 overflow-x-auto" set:html={codeHtml}></pre>
        </div>
        <p class="text-center text-xs text-surface-500 font-mono">→ generates CMS table · forms · DB schema · REST API · GraphQL</p>
    </div>

</section>

---
// src/pages/startups.astro
import Layout from "../layouts/Layout.astro";
import StartupsContent from "../components/pages/StartupsContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Startups", url: "https://firecms.co/startups" }
];
---

<Layout
        title={t('seo.startups.title')}
        description={t('seo.startups.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <StartupsContent lang={lang} t={t} />
</Layout>

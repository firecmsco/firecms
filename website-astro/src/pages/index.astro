---
import Layout from "../layouts/Layout.astro";
import ScrollSyncShowcase from "../components/ScrollSyncShowcase.astro";
import CollectionPowerSection from "../components/CollectionPowerSection.astro";
import SpotlightCard from "../components/SpotlightCard.astro";
import SectionBackgroundAccents from "../components/SectionBackgroundAccents.astro";

const title = "Rebase — The Open-Source Postgres Admin Panel for Developers";
const description = "Connect your PostgreSQL database and get a full admin panel, REST & GraphQL APIs, a built-in SQL editor, and row-level security — in minutes. Open-source, self-hostable, built in Europe.";

---

<Layout title={title} description={description}>

    <main>

        <!-- Hero -->
        <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-20 sm:pt-32 sm:pb-28 lg:pt-44 lg:pb-36">

            <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
                <!-- EU badge -->
                <div class="mb-8 flex items-center justify-center gap-3 animate-on-scroll fade-in">
                    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-surface-700 bg-surface-900/60 text-sm font-medium text-surface-300">
                        <span class="inline-block text-base">🇪🇺</span>
                        Open-source · Postgres-native · Built in Europe
                    </span>
                </div>

                <h1 class="mb-8 text-5xl sm:text-6xl font-extrabold tracking-tight leading-[1.1] md:text-6xl lg:text-7xl text-white font-sans animate-on-scroll fade-in-up">
                    From Postgres to<br/>
                    <span class="text-primary subtle-shimmer">production admin</span><br/>
                    in minutes.
                </h1>
                <p class="mt-8 text-xl leading-8 text-surface-400 max-w-2xl mx-auto font-light">
                    Connect your database. Get a <b class="text-white font-medium">full admin panel</b>,
                    REST & GraphQL APIs, a <b class="text-white font-medium">SQL editor</b>,
                    and <b class="text-white font-medium">row-level security</b> — all from your existing schema.
                </p>
                <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-on-scroll fade-in-up">
                    <a href="/docs"
                       data-track
                       id="hero-start-building"
                       class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                        Get Started
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                             class="h-5 w-5 text-white filter invert"/>
                    </a>
                    <a href="https://github.com/FireCMSco/firecms"
                       data-track
                       id="hero-explore-self-hosted"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-900/50 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-800 transition-all duration-200 ease-in-out">
                        View on GitHub
                    </a>
                </div>
            </div>

        </section>

        <!-- Product video -->
        <section class="bg-black py-4 sm:py-8">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-[1000px] animate-on-scroll fade-in-up">
                    <video
                            class="aspect-[607/373] bg-surface-950 border border-surface-800 rounded-xl flex flex-col items-center justify-center gap-4 shadow-2xl shadow-primary/5"
                            style="pointer-events: none;"
                            loop
                            autoplay
                            muted
                            playsinline>
                        <source src="/img/landing_1080.webm" type="video/webm"/>
                    </video>
                </div>
            </div>
        </section>

        <!-- One Collection. Everything. -->
        <CollectionPowerSection/>

        <!-- Scroll-sync feature showcase -->
        <ScrollSyncShowcase/>

        <!-- 6 core value props -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents topLine={true}/>

            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">
                        Everything you need. Nothing you don't.
                    </h2>
                    <p class="mt-4 text-lg text-surface-400">
                        A complete toolkit that works with your existing Postgres database.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 animate-on-scroll fade-in-up delay-100">
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/database.svg"
                            title="Postgres-native"
                            description="Reads your existing schema, respects your constraints, and works with the database you already trust. No migration, no new data layer."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layout-panel-left.svg"
                            title="Instant admin UI"
                            description="Spreadsheet-like tables, forms, Kanban boards, and filters generated straight from your schema. No boilerplate, no repetitive CRUD code."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/radio.svg"
                            title="Real-time everywhere"
                            description="Every table, form, and Kanban view stays in sync. When data changes, all connected clients see updates instantly — no refresh needed."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg"
                            title="Row-level security"
                            description="Define dynamic RLS policies in TypeScript. Fine-grained permissions per collection, per field, per user role."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code.svg"
                            title="Code-first, not code-only"
                            description="Define collections in TypeScript or build them in the UI. Override any component, inject custom React views, and extend with hooks."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/server.svg"
                            title="Self-host anywhere"
                            description="A React SPA plus a lightweight Node.js backend. Deploy on Docker, Railway, Fly, or bare metal — no vendor lock-in, ever."
                    />
                </div>
            </div>
        </section>

        <!-- SQL Editor + RLS Showcase -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "top", size: "md" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">

                <!-- SQL Editor -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24 animate-on-scroll fade-in-up">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/terminal.svg" alt="" class="h-4 w-4 filter invert opacity-80"/>
                            Differentiator
                        </div>
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">
                            A SQL editor built<br/>into your admin panel
                        </h2>
                        <p class="text-lg text-surface-400 mb-6">
                            No more switching between pgAdmin and your CMS.
                            Rebase ships a full-featured SQL editor with autocomplete,
                            query explain visualization, inline result editing, and snippet favorites.
                        </p>
                        <ul class="space-y-3">
                            {[
                                "SQL autocomplete with keyword + table suggestions",
                                "Visual EXPLAIN query plans",
                                "Edit query results inline — changes write back to Postgres",
                                "Save and organize favorite queries"
                            ].map(item => (
                                <li class="flex items-start gap-3 text-surface-300 text-sm">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check.svg" alt="" class="h-4 w-4 filter invert opacity-60 mt-0.5 flex-shrink-0"/>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-700/50 bg-surface-950 p-6">
                        <!-- Mock SQL editor UI -->
                        <div class="flex items-center gap-2 mb-4">
                            <div class="flex gap-1.5">
                                <div class="w-3 h-3 rounded-full bg-surface-700"></div>
                                <div class="w-3 h-3 rounded-full bg-surface-700"></div>
                                <div class="w-3 h-3 rounded-full bg-surface-700"></div>
                            </div>
                            <span class="text-xs text-surface-500 ml-2 font-mono">SQL Editor</span>
                        </div>
                        <div class="bg-surface-900/80 rounded-lg p-4 font-mono text-sm mb-4">
                            <div class="text-blue-400">SELECT</div>
                            <div class="pl-4 text-surface-300">p.name, p.price, c.name <span class="text-blue-400">AS</span> category</div>
                            <div class="text-blue-400">FROM</div>
                            <div class="pl-4 text-surface-300">products p</div>
                            <div class="text-blue-400">JOIN</div>
                            <div class="pl-4 text-surface-300">categories c <span class="text-blue-400">ON</span> p.category_id = c.id</div>
                            <div class="text-blue-400">WHERE</div>
                            <div class="pl-4 text-surface-300">p.price > <span class="text-amber-400">100</span></div>
                            <div class="text-blue-400">ORDER BY</div>
                            <div class="pl-4 text-surface-300">p.price <span class="text-blue-400">DESC</span>;</div>
                        </div>
                        <div class="bg-surface-900/60 rounded-lg overflow-hidden">
                            <div class="grid grid-cols-3 text-xs font-semibold text-surface-400 uppercase px-3 py-2 border-b border-surface-800">
                                <span>name</span><span>price</span><span>category</span>
                            </div>
                            {[
                                ["Ergonomic Chair", "€299.00", "Furniture"],
                                ["Standing Desk", "€549.00", "Furniture"],
                                ["4K Monitor", "€449.00", "Electronics"],
                            ].map(row => (
                                <div class="grid grid-cols-3 text-sm text-surface-300 px-3 py-2 border-b border-surface-800/50 hover:bg-surface-800/30">
                                    <span>{row[0]}</span><span class="text-amber-400/80">{row[1]}</span><span>{row[2]}</span>
                                </div>
                            ))}
                        </div>
                        <div class="mt-3 flex items-center gap-2 text-xs text-surface-500">
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-green-500/10 text-green-400 text-xs font-medium">✓ 3 rows</span>
                            <span>12ms</span>
                        </div>
                    </div>
                </div>

                <!-- RLS -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center animate-on-scroll fade-in-up">
                    <div class="lg:order-last">
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg" alt="" class="h-4 w-4 filter invert opacity-80"/>
                            Enterprise-ready
                        </div>
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">
                            Row-level security<br/>without the headache
                        </h2>
                        <p class="text-lg text-surface-400 mb-6">
                            Define Postgres RLS policies directly from the Rebase UI using TypeScript.
                            No hand-written SQL policies, no guessing about who can access what.
                        </p>
                        <ul class="space-y-3">
                            {[
                                "Create and edit RLS policies visually",
                                "Define dynamic policies in TypeScript",
                                "Per-collection, per-field, per-role permissions",
                                "Live preview of policy effects"
                            ].map(item => (
                                <li class="flex items-start gap-3 text-surface-300 text-sm">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check.svg" alt="" class="h-4 w-4 filter invert opacity-60 mt-0.5 flex-shrink-0"/>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="relative rounded-2xl overflow-hidden ring-1 ring-surface-700/50 bg-surface-950 p-6">
                        <!-- Mock RLS policy UI -->
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-semibold text-white">RLS Policies — <span class="text-primary">products</span></span>
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-green-500/10 text-green-400 text-xs font-medium">RLS enabled</span>
                        </div>
                        <div class="space-y-3">
                            {[
                                { name: "admin_full_access", action: "ALL", role: "admin", using: "true" },
                                { name: "team_read_own", action: "SELECT", role: "editor", using: "team_id = current_user_team()" },
                                { name: "public_read_published", action: "SELECT", role: "viewer", using: "status = 'published'" },
                            ].map(policy => (
                                <div class="bg-surface-900/80 rounded-lg p-3 ring-1 ring-surface-800/50">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="text-sm font-medium text-white">{policy.name}</span>
                                        <div class="flex items-center gap-2">
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-400">{policy.action}</span>
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-purple-500/10 text-purple-400">{policy.role}</span>
                                        </div>
                                    </div>
                                    <div class="font-mono text-xs text-surface-400">
                                        <span class="text-blue-400">USING</span> ({policy.using})
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- EU / data sovereignty section -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "top", size: "md" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="animate-on-scroll fade-in-up">
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                            <span class="text-base" aria-hidden="true">🇪🇺</span>
                            Truly European
                        </div>
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">
                            Stop sending your data<br/>across the Atlantic
                        </h2>
                        <p class="text-lg text-surface-400 mb-8">
                            Rebase is designed and built in Europe, and because it's fully self-hosted,
                            you decide exactly where your data lives.
                            No surprise transfers, no vendor lock-in, no CLOUD Act exposure.
                        </p>
                        <ul class="space-y-4">
                            {[
                                "Self-host in any region — full control over where data lives",
                                "GDPR-compliant by design, not by patch",
                                "Self-host anywhere in the world on your own infrastructure",
                                "Open-source core — audit every line"
                            ].map(item => (
                                <li class="flex items-start gap-3 text-surface-300">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check.svg" alt="" class="h-5 w-5 filter invert opacity-60 mt-0.5 flex-shrink-0"/>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="animate-on-scroll fade-in-up delay-100">
                        <div class="grid grid-cols-1 gap-6">
                            <SpotlightCard
                                    icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/globe.svg"
                                    title="No vendor lock-in"
                                    description="Your data lives in a standard PostgreSQL database. Switch providers, self-host, or export anytime. Nobody holds your data hostage."
                            />
                            <SpotlightCard
                                    icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/lock.svg"
                                    title="Role-based access control"
                                    description="Fine-grained permissions per collection, per field, per user role. Keep sensitive data private without complex custom code."
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- More power features -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "bottom", size: "lg" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">And so much more</h2>
                    <p class="mt-4 text-surface-400 text-lg">Powerful features that keep shipping. Every view updates in real time.</p>
                </div>

                <!-- Row 1: Real admin view showcases -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto mb-6">
                    <!-- Kanban board views -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950">
                            <video
                                class="w-full h-full object-cover object-top"
                                style="pointer-events: none;"
                                loop
                                autoplay
                                muted
                                playsinline>
                                <source src="/img/dnd.webm" type="video/webm"/>
                            </video>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/kanban.svg" alt="" class="h-3.5 w-3.5 filter invert"/>
                                </div>
                                <h3 class="text-base font-semibold text-white">Kanban board views</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Drag & drop
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Visualize and manage your Postgres records as interactive Kanban boards. Drag cards between columns to update status fields instantly.</p>
                        </div>
                    </div>

                    <!-- Data history & audit -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950">
                            <img
                                src="/img/history.png"
                                alt="Data history and audit view"
                                class="w-full h-full object-cover object-top"/>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/history.svg" alt="" class="h-3.5 w-3.5 filter invert"/>
                                </div>
                                <h3 class="text-base font-semibold text-white">Data history & audit</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Versioning
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Track who changed what and when. Compare versions side by side and safely revert to any previous state with one click.</p>
                        </div>
                    </div>

                    <!-- Import & export -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950">
                            <video
                                class="w-full h-full object-cover object-top"
                                style="pointer-events: none;"
                                loop
                                autoplay
                                muted
                                playsinline>
                                <source src="/img/import.webm" type="video/webm"/>
                            </video>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/upload.svg" alt="" class="h-3.5 w-3.5 filter invert"/>
                                </div>
                                <h3 class="text-base font-semibold text-white">Import & export</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Bulk ops
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Bulk import from CSV, JSON, or Excel with automatic field mapping. One-click export for backups and reporting.</p>
                        </div>
                    </div>
                </div>

                <!-- Row 2: Icon + text cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
                    {[
                        {
                            icon: "sparkles",
                            title: "AI content generation",
                            desc: "Context-aware autofill that understands your schema. Generate titles, descriptions, translations in one click."
                        },
                        {
                            icon: "file-text",
                            title: "Notion-style editor",
                            desc: "A rich text editor with slash commands, media embeds, and structured content — built in as a field type."
                        },
                        {
                            icon: "puzzle",
                            title: "React extensibility",
                            desc: "Custom fields, entity views, or entire pages — if you can build it in React, you can build it in Rebase."
                        },
                    ].map(item => (
                        <div class="group relative p-6 rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up">
                            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 ring-1 ring-primary/20">
                                <img src={`https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/${item.icon}.svg`} alt="" class="h-5 w-5 filter invert"/>
                            </div>
                            <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
                            <p class="text-surface-400 text-sm leading-relaxed">{item.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="bg-black py-24 sm:py-32 border-t border-surface-800/40">
            <div class="mx-auto max-w-7xl px-6">
                <div class="mx-auto max-w-3xl text-center animate-on-scroll fade-in-up">
                    <h2 class="text-3xl sm:text-4xl font-medium text-white">Frequently asked questions</h2>
                </div>
                <div class="mt-10 max-w-3xl mx-auto space-y-4 animate-on-scroll fade-in-up delay-100">
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">What database does Rebase support?</summary>
                        <p class="mt-2 text-surface-300">Rebase is built on <strong>PostgreSQL</strong>. You connect your own Postgres database — Rebase introspects the schema and generates a full admin interface automatically. No extra database, no data migration required.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">How is Rebase different from Retool or Supabase?</summary>
                        <p class="mt-2 text-surface-300">Unlike Retool, Rebase is open-source with no per-seat pricing lock-in, and it's a real React framework you can extend with your own code. Unlike Supabase, Rebase works with <em>your existing</em> Postgres database — it's not a BaaS that owns your infrastructure. You keep full control.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Can I use Rebase with an existing database?</summary>
                        <p class="mt-2 text-surface-300">Yes — that's the primary use case. Connect any Postgres database and Rebase will introspect the schema to generate an admin panel automatically. You can then refine the UI visually or in TypeScript.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Is Rebase open-source?</summary>
                        <p class="mt-2 text-surface-300">Yes. The core framework is MIT-licensed and open-source. A PRO license unlocks advanced UI components (schema editor, data import/export, user management UI) and priority support.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">What's the tech stack?</summary>
                        <p class="mt-2 text-surface-300">The admin panel is a <strong>React 19 SPA</strong> built with TypeScript and Tailwind CSS. The backend is a lightweight <strong>Node.js</strong> service that connects directly to your PostgreSQL database. No SSR, no monolithic framework.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Do you support SSO or enterprise auth?</summary>
                        <p class="mt-2 text-surface-300">Yes. SSO, SAML, and advanced enterprise authentication are available on Enterprise plans. Reach out to talk through your requirements.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Can I embed Rebase inside my existing React app?</summary>
                        <p class="mt-2 text-surface-300">Yes. Rebase is distributed as npm packages. You can mount the entire admin panel inside your existing React application, or deploy it as a standalone SPA. It's designed to be embeddable.</p>
                    </details>
                </div>
            </div>
        </section>


---
import Layout from "../layouts/Layout.astro";
import ScrollSyncShowcase from "../components/ScrollSyncShowcase.astro";
import CollectionPowerSection from "../components/CollectionPowerSection.astro";
import SpotlightCard from "../components/SpotlightCard.astro";
import SectionBackgroundAccents from "../components/SectionBackgroundAccents.astro";

const title = "Rebase — The Postgres Admin Panel Built for Developers";
const description = "Rebase is an open-source admin framework built on PostgreSQL. Own your data. Run it your way. Ship internal tools, back-office apps, and data workspaces faster than ever — with a database you already trust.";

---

<Layout title={title} description={description}>

    <main>

        <!-- Hero -->
        <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-24 sm:pt-32 sm:pb-32 lg:pt-48 lg:pb-48">

            <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
                <!-- EU badge -->
                <div class="mb-8 flex items-center justify-center gap-3 animate-on-scroll fade-in">
                    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-surface-700 bg-surface-900/60 text-sm font-medium text-surface-300">
                        <span class="inline-block text-base">🇪🇺</span>
                        Open-source · Postgres-native · Built in Europe
                    </span>
                </div>

                <h1 class="mb-8 text-5xl sm:text-6xl font-extrabold tracking-tight leading-none md:text-6xl lg:text-7xl text-white font-sans animate-on-scroll fade-in-up">
                    Your data.<br/>
                    <span class="text-primary subtle-shimmer">Your rules.</span>
                </h1>
                <p class="mt-8 text-xl leading-8 text-surface-400 max-w-2xl mx-auto font-light">
                    An <b class="text-white font-medium">internal tools framework</b> built directly on your PostgreSQL database.<br/>
                    Open-source. Instant GraphQL APIs. React 19.
                </p>
                <div class="flex flex-wrap items-center justify-center gap-4 animate-on-scroll fade-in-up">
                    <a href="mailto:hello@rebase.pro?subject=Rebase%20Early%20Access"
                       data-track
                       id="hero-start-building"
                       class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                        Request early access
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                             class="h-5 w-5 text-white filter invert"/>
                    </a>
                    <a href="https://github.com/FireCMSco/firecms"
                       data-track
                       id="hero-explore-self-hosted"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-900/50 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-800 transition-all duration-200 ease-in-out">
                        View on GitHub
                    </a>
                </div>
            </div>

        </section>

        <!-- 3 core value props -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
            <SectionBackgroundAccents topLine={true}/>

            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">
                        The admin layer your Postgres database deserves
                    </h2>
                    <p class="mt-4 text-lg text-surface-400">
                        Connect your database. Get a fully functional CMS in minutes.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 animate-on-scroll fade-in-up delay-100">
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layout-list.svg"
                            title="Define collections easily"
                            description="Build your database schema directly in the UI or write it in TypeScript. Rebase maps perfectly to your Postgres tables."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/sparkles.svg"
                            title="Get the perfect UI"
                            description="Instant, beautiful spreadsheet-like interfaces for your data. No more building internal tools from scratch."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code.svg"
                            title="Limitless customization"
                            description="It's a framework, not a black box. Override any component, inject your own React views, and write custom hooks."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg"
                            title="API & Security out of the box"
                            description="Instant REST API and fine-grained Role-Based Access Control (RBAC) securely locked down from day one."
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/server.svg"
                            title="Self-host anywhere"
                            description="Deploy the Node.js backend and React frontend wherever you want. Docker, VPS, or PaaS — you own the infrastructure."
                    />
                </div>
            </div>
        </section>

        <!-- Scroll-sync feature showcase -->
        <ScrollSyncShowcase/>

        <!-- One Collection. Everything. -->
        <CollectionPowerSection/>

        <!-- EU / data sovereignty section -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "top", size: "md" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="animate-on-scroll fade-in-up">
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                            <span class="text-base" aria-hidden="true">🇪🇺</span>
                            Truly European
                        </div>
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">
                            Stop sending your data<br/>across the Atlantic
                        </h2>
                        <p class="text-lg text-surface-400 mb-8">
                            Rebase is a Postgres data workspace designed, built, and operated entirely within the EU. 
                            We don't just "comply" with GDPR — data sovereignty is our core architecture. 
                            Your data stays in Europe, under your control, free from the CLOUD Act.
                        </p>
                        <ul class="space-y-4">
                            {[
                                "EU infrastructure — no surprise data transfers",
                                "GDPR-compliant by design, not by patch",
                                "Self-host anywhere in the world on your own infrastructure",
                                "Open-source core — audit every line"
                            ].map(item => (
                                <li class="flex items-start gap-3 text-surface-300">
                                    <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/check.svg" alt="" class="h-5 w-5 filter invert opacity-60 mt-0.5 flex-shrink-0"/>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="animate-on-scroll fade-in-up delay-100">
                        <div class="grid grid-cols-1 gap-6">
                            <SpotlightCard
                                    icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/globe.svg"
                                    title="No vendor lock-in"
                                    description="Your data lives in a standard PostgreSQL database. Switch providers, self-host, or export anytime. Nobody holds your data hostage."
                            />
                            <SpotlightCard
                                    icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/lock.svg"
                                    title="Role-based access control"
                                    description="Fine-grained permissions per collection, per field, per user role. Keep sensitive data private without complex custom code."
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Hidden temporarily to streamline the hype/launch page 

        <!-- Built with modern tech -->
        <section class="bg-black py-16 sm:py-24">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <p class="text-center text-sm font-medium text-surface-500 mb-10 uppercase tracking-wider">
                    Built with modern technologies
                </p>
                <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-16">
                    <img class="h-10 w-auto opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                         src="/img/reactjs-icon.svg" alt="React">
                    <img class="h-10 w-auto opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                         src="/img/typescript_logo.svg" alt="TypeScript">
                    <img class="h-8 w-auto opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                         src="/img/tailwind_logo.svg" alt="Tailwind CSS">
                    <img class="h-10 w-auto opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                         src="https://www.postgresql.org/media/img/about/press/elephant.png" alt="PostgreSQL">
                </div>
            </div>
        </section>

        <!-- Architecture section -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "top", size: "sm" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
                    <div class="animate-on-scroll fade-in-up">
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm font-medium mb-6">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg" alt="" class="h-4 w-4 filter invert opacity-60"/>
                            Architecture
                        </div>
                        <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-6">
                            No SSR magic.<br/>Just a clean architecture.
                        </h2>
                        <p class="text-lg text-surface-400 mb-6">
                            Admin panels don't need server-side rendering. They need speed,
                            reliability, and the ability to run anywhere. So we didn't use Next.js.
                        </p>
                        <p class="text-surface-400">
                            Rebase is a <strong class="text-white">React SPA</strong> talking to a
                            <strong class="text-white">dedicated Node.js backend</strong> that connects directly to your Postgres database.
                            No monolithic framework, no vendor runtime, no surprise re-renders. The frontend and backend
                            are separate concerns — each deployed, scaled, and debugged independently.
                        </p>
                    </div>
                    <div class="space-y-4 animate-on-scroll fade-in-up delay-100">
                        {[
                            {
                                icon: "layout-panel-left",
                                label: "React SPA frontend",
                                desc: "A fast, embeddable React app. Mount it inside your own app or deploy it standalone. No SSR quirks, no hydration issues."
                            },
                            {
                                icon: "server",
                                label: "Dedicated REST backend",
                                desc: "A lightweight Node.js service that owns your Postgres connection, handles auth, and exposes a clean API. No runtime magic."
                            },
                            {
                                icon: "package",
                                label: "Deploy anywhere",
                                desc: "Docker, bare metal, Railway, Fly, your own VPS — the backend runs wherever Node.js runs. No platform lock-in."
                            },
                            {
                                icon: "plug",
                                label: "Embeddable by design",
                                desc: "Need internal tools inside an existing React app? Rebase is distributed as an npm package. Drop it in, configure it, ship it."
                            }
                        ].map(item => (
                            <div class="flex items-start gap-4 p-4 rounded-xl bg-surface-900/50 ring-1 ring-surface-800">
                                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20 flex-shrink-0 mt-0.5">
                                    <img src={`https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/${item.icon}.svg`}
                                         alt="" class="h-4 w-4 filter invert opacity-80"/>
                                </div>
                                <div>
                                    <div class="font-semibold text-white text-sm mb-1">{item.label}</div>
                                    <p class="text-surface-400 text-sm">{item.desc}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>


        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
            <SectionBackgroundAccents topLine={true} blob={{ position: "bottom", size: "md" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">Made for teams who care about their data</h2>
                    <p class="mt-4 text-surface-400 text-lg">Whether you're a solo developer or a growing team.</p>
                </div>
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/rocket.svg"
                            title="Startups"
                            description="Ship your MVP's back-office in hours. Grow into it — add custom views and logic as your product evolves."
                            link={{ href: "/startups", text: "Learn More" }}
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/briefcase.svg"
                            title="Agencies"
                            description="Deliver white-labeled, self-hosted admin tools to clients. You own the stack, they love the product."
                            link={{ href: "/agencies", text: "Learn More" }}
                    />
                    <SpotlightCard
                            icon="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/code.svg"
                            title="Developers"
                            description="Full TypeScript, extensible architecture, open-source core. Rebase gets out of your way and lets you build."
                            link={{ href: "/developers", text: "Learn More" }}
                    />
                </div>
            </div>
        </section>
        
        */}

        <!-- Power Features Section -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "bottom", size: "lg" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/sparkles.svg" alt="" class="h-4 w-4 filter invert opacity-80"/>
                        New in Rebase
                    </div>
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">Next-Generation Power Features</h2>
                    <p class="mt-4 text-surface-400 text-lg">We're shipping at lightspeed. Check out what's new.</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto">
                    <!-- Feature 1: AI MCP -->
                    <div class="col-span-1 rounded-2xl bg-surface-900/50 p-8 ring-1 ring-inset ring-surface-800">
                        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/clock.svg" alt=""
                                 class="h-6 w-6 filter invert"/>
                        </div>
                        <h3 class="text-xl font-semibold tracking-tight text-white mb-3">Live in minutes</h3>
                        <p class="text-surface-400">
                            Connect your database. Get a fully functional admin panel in minutes without writing repetitive boilerplate code.
                        </p>
                    </div>

                    <!-- Feature 2: RLS -->
                    <div class="group relative p-8 rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/50 transition-all duration-300 animate-on-scroll fade-in-up delay-75">
                        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 ring-1 ring-primary/20">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg" alt="Security" class="h-6 w-6 filter invert"/>
                        </div>
                        <h3 class="text-xl font-semibold text-white mb-3">Row Level Security (RLS)</h3>
                        <p class="text-surface-400 leading-relaxed">
                            Enterprise-grade security without the hassle. Secure your Postgres data down to the individual row using intuitive, dynamic TypeScript policies directly inside Rebase.
                        </p>
                    </div>

                    <!-- Feature 3: Kanban -->
                    <div class="group relative p-8 rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/50 transition-all duration-300 animate-on-scroll fade-in-up delay-100">
                        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 ring-1 ring-primary/20">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/kanban.svg" alt="Kanban Boards" class="h-6 w-6 filter invert"/>
                        </div>
                        <h3 class="text-xl font-semibold text-white mb-3">Kanban Board Views</h3>
                        <p class="text-surface-400 leading-relaxed">
                            Your data doesn't have to be just spreadsheets. Instantly visualize and manage your Postgres records as interactive, drag-and-drop Kanban boards.
                        </p>
                    </div>

                    <!-- Feature 4: SQL Editor -->
                    <div class="group relative p-8 rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/50 transition-all duration-300 animate-on-scroll fade-in-up delay-150">
                        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 ring-1 ring-primary/20">
                            <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/terminal.svg" alt="SQL Editor" class="h-6 w-6 filter invert"/>
                        </div>
                        <h3 class="text-xl font-semibold text-white mb-3">Built-in SQL Editor</h3>
                        <p class="text-surface-400 leading-relaxed">
                            Never leave the UI. A fully-featured, built-in SQL editor connects directly to your Postgres database for complex migrations, raw queries, and immediate data manipulation.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="bg-black py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6">
                <div class="mx-auto max-w-3xl text-center animate-on-scroll fade-in-up">
                    <h2 class="text-3xl sm:text-4xl font-medium text-white">Frequently asked questions</h2>
                </div>
                <div class="mt-10 max-w-3xl mx-auto space-y-4 animate-on-scroll fade-in-up delay-100">
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">What database does Rebase use?</summary>
                        <p class="mt-2 text-surface-300">Rebase is built on <strong>PostgreSQL</strong>. You connect your own Postgres database and Rebase automatically generates a full admin interface on top of it — no extra database, no data migration required.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Is my data safe with Rebase?</summary>
                        <p class="mt-2 text-surface-300">Yes. Your data lives in your own Postgres database — Rebase never copies or stores it. Our open-source codebase can be audited and self-hosted at any time.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Can I use Rebase with an existing database?</summary>
                        <p class="mt-2 text-surface-300">Yes, that's the primary use case. Connect any Postgres database and Rebase will introspect the schema to generate an admin panel automatically. You can then refine the UI visually without writing config files.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Is Rebase open-source?</summary>
                        <p class="mt-2 text-surface-300">Yes. The core framework is MIT-licensed and open-source. A PRO license unlocks advanced UI components, theming, and premium support.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Do you support SSO or enterprise auth?</summary>
                        <p class="mt-2 text-surface-300">Yes. SSO, SAML, and advanced enterprise authentication are available on Enterprise plans. Reach out to talk through your requirements.</p>
                    </details>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
            <SectionBackgroundAccents topLine={true} blob={{ position: "top", size: "lg" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-4 animate-on-scroll fade-in-up">
                    Ready to own your data?
                </h2>
                <p class="text-surface-400 mb-10 text-lg animate-on-scroll fade-in-up">
                    Start in minutes. No credit card required.
                </p>
                <div class="flex flex-wrap items-center justify-center gap-4 animate-on-scroll fade-in-up delay-100">
                    <a href="mailto:hello@rebase.pro?subject=Rebase%20Early%20Access"
                       data-track
                       id="cta-try-rebase"
                       class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                        Request early access
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                             class="h-5 w-5 text-white filter invert"/>
                    </a>
                    <a href="https://github.com/FireCMSco/firecms"
                       data-track
                       id="cta-view-docs"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-x-2 text-white hover:text-primary transition-colors font-semibold">
                        View on GitHub
                        <img src="https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/arrow-right.svg" alt=""
                             class="h-4 w-4 text-white filter invert"/>
                    </a>
                </div>
            </div>
        </section>


    </main>

</Layout>

---
// src/pages/[lang]/pro.astro
import Layout from "../../layouts/Layout.astro";
import ProContent from "../../components/pages/ProContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "PRO", url: "https://firecms.co/pro" }
];
---

<Layout
        title={t('seo.pro.title')}
        description={t('seo.pro.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <ProContent lang={lang} t={t} />
</Layout>

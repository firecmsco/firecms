---
import Layout from "../../layouts/Layout.astro";
import FeaturesContent from "../../components/pages/FeaturesContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

// TODO: translate SEO breadcrumbs
const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Features", url: "https://firecms.co/features" }
];
---

<Layout
        title={t('seo.features.title')}
        description={t('seo.features.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <FeaturesContent lang={lang} t={t} />
</Layout>

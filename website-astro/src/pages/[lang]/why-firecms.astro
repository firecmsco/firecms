---
// src/pages/[lang]/why-firecms.astro
import Layout from "../../layouts/Layout.astro";
import WhyFireCMSContent from "../../components/pages/WhyFireCMSContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Why FireCMS", url: "https://firecms.co/why-firecms" }
];
---

<Layout
        title={t('seo.why.title')}
        description={t('seo.why.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <WhyFireCMSContent lang={lang} t={t} />
</Layout>

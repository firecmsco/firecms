---
// src/pages/[lang]/ui.astro
import Layout from "../../layouts/Layout.astro";
import UIContent from "../../components/pages/UIContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "UI Components", url: "https://firecms.co/ui" }
];
---

<Layout
        title={t('seo.ui.title')}
        description={t('seo.ui.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <UIContent lang={lang} t={t} />
</Layout>

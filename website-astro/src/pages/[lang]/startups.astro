---
// src/pages/[lang]/startups.astro
import Layout from "../../layouts/Layout.astro";
import StartupsContent from "../../components/pages/StartupsContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Startups", url: "https://firecms.co/startups" }
];
---

<Layout
        title={t('seo.startups.title')}
        description={t('seo.startups.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <StartupsContent lang={lang} t={t} />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import AboutContent from "../../components/pages/AboutContent.astro";
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
    const supportedLangs = Object.keys(languages).filter(l => l !== 'en');
    return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "About", url: "https://firecms.co/about" }
];
---

<Layout
        title={t('seo.about.title')}
        description={t('seo.about.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <AboutContent lang={lang} t={t} />
</Layout>

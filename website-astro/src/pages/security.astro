---
// src/pages/security.astro
import Layout from "../layouts/Layout.astro";
import SecurityContent from "../components/pages/SecurityContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Security", url: "https://firecms.co/security" }
];
---

<Layout
        title={t('seo.security.title')}
        description={t('seo.security.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <SecurityContent lang={lang} t={t} />
</Layout>

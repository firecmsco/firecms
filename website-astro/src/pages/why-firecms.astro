---
// src/pages/why-firecms.astro
import Layout from "../layouts/Layout.astro";
import WhyFireCMSContent from "../components/pages/WhyFireCMSContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Why FireCMS", url: "https://firecms.co/why-firecms" }
];
---

<Layout
        title={t('seo.why.title')}
        description={t('seo.why.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <WhyFireCMSContent lang={lang} t={t} />
</Layout>

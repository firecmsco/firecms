---
// src/pages/compare.astro
import Layout from "../layouts/Layout.astro";
import CompareContent from "../components/pages/CompareContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Compare", url: "https://firecms.co/compare" }
];
---

<Layout
        title={t('seo.compare.title')}
        description={t('seo.compare.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <CompareContent lang={lang} t={t} />
</Layout>

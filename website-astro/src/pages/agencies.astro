---
// src/pages/agencies.astro
import Layout from "../layouts/Layout.astro";
import AgenciesContent from "../components/pages/AgenciesContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Agencies", url: "https://firecms.co/agencies" }
];
---

<Layout
        title={t('seo.agencies.title')}
        description={t('seo.agencies.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <AgenciesContent lang={lang} t={t} />
</Layout>

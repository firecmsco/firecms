---
import Layout from "../layouts/Layout.astro";

const title = "Get Early Access — Rebase";
const description = "Join the waitlist for Rebase, the open-source Postgres CMS.";
---
<Layout title={title} description={description}>
    <main class="min-h-screen flex items-center justify-center py-24 sm:py-32 relative isolate overflow-hidden pt-32">
        <!-- Background accents -->
        <div class="absolute inset-0 -z-10 h-full w-full bg-black [background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#0070f4_100%)] opacity-30"></div>
        <div class="absolute inset-0 bg-[url(/img/grid.svg)] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] -z-10 opacity-20"></div>

        <div class="mx-auto max-w-xl px-6 text-center animate-on-scroll fade-in-up">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-8">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                </span>
                Closed Beta
            </div>
            
            <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-white mb-6 leading-tight">
                Get early access to <span class="text-primary">Rebase</span>
            </h1>
            
            <p class="mt-4 text-xl text-surface-400 mb-12 font-light">
                We're currently letting in new teams on a rolling basis. Join the waitlist to secure your spot for the open-source Postgres CMS.
            </p>
            
            <div class="relative bg-surface-900/60 backdrop-blur-sm p-2 sm:p-3 rounded-2xl ring-1 ring-surface-800 shadow-2xl focus-within:ring-primary/50 transition-all mb-8 max-w-md mx-auto">
                <form id="waitlist-form" onsubmit="
                    event.preventDefault(); 
                    document.getElementById('waitlist-form').classList.add('hidden'); 
                    document.getElementById('success-message').classList.remove('hidden');
                    // Send analytics event if needed
                    if (typeof window.gtag === 'function') {
                        window.gtag('event', 'generate_lead', {
                            event_category: 'waitlist',
                            currency: 'USD',
                            value: 1
                        });
                    }
                " class="flex flex-col sm:flex-row w-full items-center gap-3">
                    <input type="email" required placeholder="Enter your work email" class="w-full flex-auto bg-surface-950/50 px-5 py-4 text-base text-white placeholder-surface-500 rounded-xl focus:outline-none border border-surface-700/50 focus:border-primary/50 focus:bg-black transition-all" />
                    <button type="submit" class="w-full sm:w-auto flex-none rounded-xl bg-primary px-8 py-4 font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all btn-glow whitespace-nowrap text-base">
                        Request Access
                    </button>
                </form>
                
                <div id="success-message" class="hidden p-8 text-center animate-in fade-in zoom-in duration-300">
                    <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-green-500/20 ring-1 ring-green-500/40">
                        <svg class="h-8 w-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">You're on the list!</h3>
                    <p class="text-surface-300">Keep an eye on your inbox. We'll reach out as soon as we have a spot for you.</p>
                </div>
            </div>
            
            <p class="text-sm text-surface-500 font-medium">
                Are you an enterprise team? <a href="/contact" class="text-primary hover:text-primary-light transition-colors hover:underline">Contact sales</a>
            </p>
        </div>
    </main>
</Layout>

---
// src/pages/ui.astro
import Layout from "../layouts/Layout.astro";
import UIContent from "../components/pages/UIContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "UI Components", url: "https://firecms.co/ui" }
];
---

<Layout
        title={t('seo.ui.title')}
        description={t('seo.ui.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <UIContent lang={lang} t={t} />
</Layout>

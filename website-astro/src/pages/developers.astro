---
import Layout from "../layouts/Layout.astro";
import DevelopersContent from "../components/pages/DevelopersContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Developers", url: "https://firecms.co/developers" }
];
---

<Layout
        title={t('seo.developers.title')}
        description={t('seo.developers.description')}
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <DevelopersContent lang={lang} t={t} />
</Layout>

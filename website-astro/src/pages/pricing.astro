---
// src/pages/pricing.astro
import Layout from "../layouts/Layout.astro";
import PricingContent from "../components/pages/PricingContent.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const breadcrumbs = [
    { name: "Home", url: "https://firecms.co" },
    { name: "Pricing", url: "https://firecms.co/pricing" }
];
---

<Layout
        title="FireCMS Pricing - Cloud Trial & Self-Hosted Options"
        description="Explore FireCMS plans: Start with our free Community version (self-hosted), try Cloud free for a month, or unlock PRO features."
        breadcrumbs={breadcrumbs}
        lang={lang}
>
    <PricingContent lang={lang} t={t} />
</Layout>

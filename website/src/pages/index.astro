---
import Layout from "../layouts/Layout.astro";
import ScrollSyncShowcase from "../components/ScrollSyncShowcase.astro";
import CollectionPowerSection from "../components/CollectionPowerSection.astro";
import SectionBackgroundAccents from "../components/SectionBackgroundAccents.astro";
import { EntityViewDemo } from "../components/demos/EntityViewDemo";
import { KanbanDemo } from "../components/demos/KanbanDemo";
import { ApiMiniDemo } from "../components/demos/ApiMiniDemo";
import { SdkMiniDemo } from "../components/demos/SdkMiniDemo";
import { RealtimeMiniDemo } from "../components/demos/RealtimeMiniDemo";
import RoadmapSection from "../components/RoadmapSection.astro";
import ClientLogos from "../components/ClientLogos.astro";

const title = "Rebase — Ship your back-office in a sprint. Extend it forever.";
const description = "Open-source Postgres platform — admin panel, REST & GraphQL APIs, and typed TypeScript SDK, all generated from your schema. Self-hosted, no vendor lock-in.";

---
<Layout title={title} description={description}>

    <main>

        <!-- Hero -->
        <section class="relative isolate overflow-hidden bg-linear-to-br from-black to-surface-950 pt-24 pb-20 sm:pt-32 sm:pb-28 lg:pt-44 lg:pb-36">

            <div class="px-4 mx-auto max-w-7xl text-center lg:px-12">
                <!-- EU badge -->
                <div class="mb-8 flex items-center justify-center gap-3 animate-on-scroll fade-in">
                    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-surface-700 bg-surface-900/60 text-sm font-medium text-surface-300">
                        <span class="inline-block text-base">🇪🇺</span>
                        Open-source · Postgres-native · Built in Europe
                    </span>
                </div>

                <h1 class="mb-8 text-5xl sm:text-6xl font-extrabold tracking-tight leading-[1.1] md:text-6xl lg:text-7xl text-white font-sans animate-on-scroll fade-in-up">
                    Ship your back-office in a <span class="text-primary subtle-shimmer">sprint</span>.<br/>
                    Extend it <span class="text-primary subtle-shimmer">forever</span>.
                </h1>
                <p class="mt-8 text-xl leading-8 text-surface-400 max-w-2xl mx-auto font-light">
                    Admin panel, APIs, and typed SDK — generated from a <b class="text-white font-medium">single TypeScript schema</b>.<br/>
                    Open-source. Postgres-native. <b class="text-white font-medium">No vendor lock-in.</b>
                </p>
                <div class="mt-6 flex flex-wrap items-center justify-center gap-2.5 animate-on-scroll fade-in">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm">
                        <span class="material-symbols-rounded text-primary" style="font-size:14px">dashboard</span>
                        Admin Panel
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm">
                        <span class="material-symbols-rounded text-primary" style="font-size:14px">api</span>
                        REST & GraphQL
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm">
                        <span class="material-symbols-rounded text-primary" style="font-size:14px">code</span>
                        Typed SDK
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm">
                        <span class="material-symbols-rounded text-primary" style="font-size:14px">lock</span>
                        Built-in Auth
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-surface-700 bg-surface-900/60 text-surface-400 text-sm">
                        <span class="material-symbols-rounded text-primary" style="font-size:14px">sync</span>
                        Real-time
                    </span>
                </div>
                <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-on-scroll fade-in-up">
                    <a href="/waitlist"
                       data-track
                       id="hero-start-building"
                       class="inline-flex items-center gap-x-2 rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all duration-200 ease-in-out btn-glow">
                        Get Early Access
                        <span class="material-symbols-rounded text-white" style="font-size:20px">arrow_forward</span>
                    </a>
                    <a href="https://github.com/rebasepro/rebase"
                       data-track
                       id="hero-explore-self-hosted"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-x-2 rounded-md border border-surface-700 bg-surface-900/50 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-surface-800 transition-all duration-200 ease-in-out">
                        View on GitHub
                    </a>
                </div>
            </div>

        </section>

        <!-- Product video -->
        <section class="bg-black py-4 sm:py-8">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-[1000px] animate-on-scroll fade-in-up">
                    <div class="w-full overflow-hidden bg-surface-950 border border-surface-800 rounded-xl flex flex-col shadow-2xl shadow-primary/5 pointer-events-none">
                        <EntityViewDemo client:load />
                    </div>
                </div>
            </div>
        </section>

        <!-- Social proof -->
        <section class="bg-black py-12 sm:py-16 border-t border-surface-800/40">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <p class="text-center text-sm text-surface-500 mb-8 animate-on-scroll fade-in">Trusted by developers and teams at</p>
                <ClientLogos />
            </div>
        </section>

        <!-- How it works -->
        <section class="bg-black py-20 sm:py-24 border-t border-surface-800/40">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">From zero to admin panel in minutes</h2>
                </div>
                <div class="relative grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 max-w-4xl mx-auto">
                    <!-- Connecting line (desktop) -->
                    <div class="hidden md:block absolute top-6 left-[calc(16.67%+24px)] right-[calc(16.67%+24px)] h-px bg-gradient-to-r from-primary/40 via-primary/20 to-primary/40"></div>

                    <!-- Step 1: Connect -->
                    <div class="relative text-center animate-on-scroll fade-in-up">
                        <div class="relative inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 ring-2 ring-primary/30 mb-6 z-10 bg-black">
                            <span class="text-lg font-bold text-primary">1</span>
                        </div>
                        <h3 class="text-lg font-semibold text-white mb-3">Connect your Postgres</h3>
                        <p class="text-surface-400 text-sm leading-relaxed">Point Rebase at any existing Postgres database. It introspects your schema — tables, types, relations — instantly.</p>
                        <div class="mt-5 rounded-lg bg-surface-900/60 border border-surface-800 px-4 py-2.5 font-mono text-xs text-surface-400 inline-block">
                            <span class="text-surface-500">$</span> npx rebase init
                        </div>
                    </div>

                    <!-- Step 2: Get everything -->
                    <div class="relative text-center animate-on-scroll fade-in-up delay-100">
                        <div class="relative inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 ring-2 ring-primary/30 mb-6 z-10 bg-black">
                            <span class="text-lg font-bold text-primary">2</span>
                        </div>
                        <h3 class="text-lg font-semibold text-white mb-3">Get everything, instantly</h3>
                        <p class="text-surface-400 text-sm leading-relaxed">Admin panel, entity forms, REST & GraphQL APIs, typed SDK, and real-time subscriptions — all generated from your schema.</p>
                    </div>

                    <!-- Step 3: Extend forever -->
                    <div class="relative text-center animate-on-scroll fade-in-up delay-200">
                        <div class="relative inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 ring-2 ring-primary/30 mb-6 z-10 bg-black">
                            <span class="text-lg font-bold text-primary">3</span>
                        </div>
                        <h3 class="text-lg font-semibold text-white mb-3">Extend forever</h3>
                        <p class="text-surface-400 text-sm leading-relaxed">Customize with TypeScript. Add callbacks, custom views, business logic, and granular permissions — all version-controlled.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- One Collection. Everything. -->
        <CollectionPowerSection/>

        <!-- Scroll-sync feature showcase -->
        <ScrollSyncShowcase/>
        <!-- Two big punches — sell feelings, link to depth -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "bottom", size: "md" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

                    <!-- Punch 1: Your database, your rules -->
                    <div class="group relative rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/40 transition-all duration-300 p-10 flex flex-col justify-between min-h-[380px]">
                        <div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                                <span class="material-symbols-rounded text-primary" style="font-size:16px">verified_user</span>
                                Security-first
                            </div>
                            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-4">
                                Your database, your rules.
                            </h2>
                            <p class="text-lg text-surface-400 leading-relaxed">
                                Row-level security defined in TypeScript. Granular permissions per collection, per field, per role.
                                No hand-written SQL policies — just clean code that lives in version control.
                            </p>
                        </div>
                        <div class="mt-8">
                            <a href="/studio"
                               class="inline-flex items-center gap-2 text-sm font-semibold text-white hover:text-primary transition-colors">
                                Explore Rebase Studio
                                <span class="material-symbols-rounded text-white" style="font-size:16px">arrow_forward</span>
                            </a>
                        </div>
                    </div>

                    <!-- Punch 2: Code you own, deploy anywhere -->
                    <div class="group relative rounded-2xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 hover:ring-primary/40 transition-all duration-300 p-10 flex flex-col justify-between min-h-[380px]">
                        <div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-6">
                                <span class="material-symbols-rounded text-primary" style="font-size:16px">fork_right</span>
                                Open source
                            </div>
                            <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-4">
                                Code you own.<br/>Deploy anywhere.
                            </h2>
                            <p class="text-lg text-surface-400 leading-relaxed">
                                MIT-licensed. Self-host on Docker, Railway, Fly, or bare metal.
                                Your data stays in your Postgres — no vendor lock-in, no surprises, no per-seat pricing.
                            </p>
                        </div>
                        <div class="mt-8 flex items-center gap-6">
                            <a href="/developers"
                               class="inline-flex items-center gap-2 text-sm font-semibold text-white hover:text-primary transition-colors">
                                For developers
                                <span class="material-symbols-rounded text-white" style="font-size:16px">arrow_forward</span>
                            </a>
                            <a href="/why-rebase"
                               class="inline-flex items-center gap-2 text-sm font-semibold text-surface-400 hover:text-white transition-colors">
                                Why Rebase?
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </section>



        <!-- Power features with videos -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden border-t border-surface-800/40">
            <SectionBackgroundAccents blob={{ position: "bottom", size: "lg" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-16 animate-on-scroll fade-in-up">
                    <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl">Production-grade, out of the box</h2>
                    <p class="mt-4 text-surface-400 text-lg">Every feature included. Every view updates in real time.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto mb-6">
                    <!-- Kanban board views -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950 pointer-events-none">
                            <KanbanDemo client:load />
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">view_kanban</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">Kanban boards</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Drag & drop
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Drag cards between columns to update status fields instantly. Your Postgres records, visualized.</p>
                        </div>
                    </div>

                    <!-- Data history & audit -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950">
                            <img
                                src="/img/history.png"
                                alt="Data history and audit view"
                                class="w-full h-full object-cover object-top"/>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">history</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">Data history & audit</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Versioning
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Track who changed what. Compare versions side by side. Revert with one click.</p>
                        </div>
                    </div>

                    <!-- Import & export -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950">
                            <video
                                class="w-full h-full object-cover object-top"
                                style="pointer-events: none;"
                                loop
                                autoplay
                                muted
                                playsinline>
                                <source src="/img/import.webm" type="video/webm"/>
                            </video>
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">upload</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">Import & export</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Bulk ops
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">CSV, JSON, or Excel — automatic field mapping in, one-click export out.</p>
                        </div>
                    </div>
                </div>

                <!-- Bottom row: product-level feature demos -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
                    <!-- Instant REST & GraphQL -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950 pointer-events-none flex items-center justify-center">
                            <ApiMiniDemo client:load />
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">api</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">Instant REST & GraphQL</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Auto-gen
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Your database generates secure, typed APIs automatically. Zero boilerplate, zero controllers.</p>
                        </div>
                    </div>

                    <!-- TypeScript SDK -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950 pointer-events-none flex items-center justify-center">
                            <SdkMiniDemo client:load />
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">code</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">TypeScript SDK</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    Type-safe
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Fully type-safe SDK with IDE auto-complete. Schema changes update your types automatically.</p>
                        </div>
                    </div>

                    <!-- Real-time everywhere -->
                    <div class="group rounded-2xl overflow-hidden ring-1 ring-surface-800 hover:ring-primary/40 transition-all duration-300 animate-on-scroll fade-in-up bg-surface-900/50">
                        <div class="aspect-[4/3] overflow-hidden bg-surface-950 pointer-events-none flex items-center justify-center">
                            <RealtimeMiniDemo client:load />
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/20">
                                    <span class="material-symbols-rounded text-white" style="font-size:14px">sync</span>
                                </div>
                                <h3 class="text-base font-semibold text-white">Real-time everywhere</h3>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-medium ring-1 ring-primary/20 ml-auto">
                                    WebSocket
                                </span>
                            </div>
                            <p class="text-surface-400 text-sm leading-relaxed">Every table, form, and Kanban view stays in sync. Data changes propagate instantly — no refresh.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Roadmap -->
        <RoadmapSection />

        <!-- FAQ -->
        <section class="bg-black py-24 sm:py-32 border-t border-surface-800/40">
            <div class="mx-auto max-w-7xl px-6">
                <div class="mx-auto max-w-3xl text-center animate-on-scroll fade-in-up">
                    <h2 class="text-3xl sm:text-4xl font-medium text-white">Frequently asked questions</h2>
                </div>
                <div class="mt-10 max-w-3xl mx-auto space-y-4 animate-on-scroll fade-in-up delay-100">
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">What database does Rebase support?</summary>
                        <p class="mt-2 text-surface-300">Rebase is built on <strong>PostgreSQL</strong>. You connect your own Postgres database — Rebase introspects the schema and generates a full admin interface automatically. No extra database, no data migration required.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">How is Rebase different from Retool or Supabase?</summary>
                        <p class="mt-2 text-surface-300">Unlike Retool, Rebase is open-source with no per-seat pricing lock-in, and it's a real React framework you can extend with your own code. Unlike Supabase, Rebase works with <em>your existing</em> Postgres database — it's not a BaaS that owns your infrastructure. You keep full control.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Can I use Rebase with an existing database?</summary>
                        <p class="mt-2 text-surface-300">Absolutely. Connect any Postgres database and Rebase will introspect the schema to generate a full admin panel automatically. You can then refine the UI visually or in TypeScript. Rebase works equally well for brand-new projects and existing databases.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Is Rebase open-source?</summary>
                        <p class="mt-2 text-surface-300">Yes. Rebase is completely free and MIT-licensed. Everything — the schema editor, data import/export, user management UI, and all features — is included at no cost.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">What's the tech stack?</summary>
                        <p class="mt-2 text-surface-300">The admin panel is a <strong>React 19 SPA</strong> built with TypeScript and Tailwind CSS. The backend is a lightweight <strong>Node.js</strong> service that connects directly to your PostgreSQL database. No SSR, no monolithic framework.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Do you support SSO or enterprise auth?</summary>
                        <p class="mt-2 text-surface-300">Yes. SSO, SAML, and advanced enterprise authentication are supported. Enterprise plans with dedicated support and SLAs are available — reach out to talk through your requirements.</p>
                    </details>
                    <details class="group rounded-xl bg-surface-900/50 ring-1 ring-inset ring-surface-800 p-4">
                        <summary class="cursor-pointer text-white font-semibold">Can I embed Rebase inside my existing React app?</summary>
                        <p class="mt-2 text-surface-300">Yes. Rebase is distributed as npm packages. You can mount the entire admin panel inside your existing React application, or deploy it as a standalone SPA. It's designed to be embeddable.</p>
                    </details>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="relative isolate bg-black py-24 sm:py-32 overflow-hidden">
            <SectionBackgroundAccents topLine={true} blob={{ position: "top", size: "lg" }}/>
            <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-medium tracking-tight text-white sm:text-4xl mb-4 animate-on-scroll fade-in-up">
                    Your Postgres deserves a real platform.
                </h2>
                <p class="text-surface-400 mb-6 text-lg max-w-xl mx-auto animate-on-scroll fade-in-up">
                    Admin panel, APIs, and SDK — ready in minutes.<br class="hidden sm:block"/>
                    Open-source, self-hosted, no per-seat pricing.
                </p>
                <div class="mb-10 animate-on-scroll fade-in-up">
                    <div class="inline-flex items-center gap-3 px-5 py-3 rounded-lg bg-surface-900/80 border border-surface-800 font-mono text-sm text-surface-300">
                        <span class="text-surface-500">$</span>
                        <span>npx rebase init</span>

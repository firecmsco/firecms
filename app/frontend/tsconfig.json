{
  "extends": "../../packages/core/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@rebasepro/auth": [
        "../../packages/auth/src"
      ],
      "@rebasepro/core": [
        "../../packages/core/src"
      ],
      "@rebasepro/firebase": [
        "../../packages/firebase/src"
      ],
      "@rebasepro/postgresql": [
        "../../packages/postgresql/src"
      ],
      "@rebasepro/types": [
        "../../packages/types/src"
      ],
      "@rebasepro/ui": [
        "../../packages/ui/src"
      ],
      "@rebasepro/editor": [
        "../../packages/editor/src"
      ],
      "@rebasepro/datatalk": [
        "../../packages/datatalk/src"
      ],
      "@rebasepro/mongodb": [
        "../../packages/mongodb/src"
      ],
      "@rebasepro/data_enhancement": [
        "../../packages/data_enhancement/src"
      ],
      "@rebasepro/collection_editor": [
        "../../packages/collection_editor/src"
      ],
      "@rebasepro/collection_editor_firebase": [
        "../../packages/collection_editor_firebase/src"
      ],
      "@rebasepro/entity_history": [
        "../../packages/entity_history/src"
      ],
      "@rebasepro/data_import": [
        "../../packages/data_import/src"
      ],
      "@rebasepro/data_export": [
        "../../packages/data_export/src"
      ],
      "@rebasepro/user_management": [
        "../../packages/user_management/src"
      ],
      "shared": [
        "../shared"
      ]
    }
  },
  "include": [
    "./src",
    "./vite.config.ts"
  ]
}
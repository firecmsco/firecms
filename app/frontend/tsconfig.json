{
  "extends": "../../packages/core/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@rebasepro/auth-rebase": [
        "../../packages/auth-rebase/src"
      ],
      "@rebasepro/core": [
        "../../packages/core/src"
      ],
      "@rebasepro/firebase": [
        "../../packages/firebase/src"
      ],
      "@rebasepro/postgresql": [
        "../../packages/postgresql/src"
      ],
      "@rebasepro/types": [
        "../../packages/types/src"
      ],
      "@rebasepro/ui": [
        "../../packages/ui/src"
      ],
      "@rebasepro/datatalk": [
        "../../packages/datatalk/src"
      ],
      "@rebasepro/data_enhancement": [
        "../../packages/data_enhancement/src"
      ],

      "@rebasepro/studio": [
        "../../packages/studio/src"
      ],
      "@rebasepro/common": [
        "../../packages/common/src"
      ],
      "@rebasepro/cms": [
        "../../packages/cms/src"
      ],
      "@rebasepro/client-rebase": [
        "../../packages/client-rebase/src"
      ],
      "@rebasepro/formex": [
        "../../packages/formex/src"
      ],
      "@rebasepro/schema_inference": [
        "../../packages/schema_inference/src"
      ],
      "shared": [
        "../shared"
      ]
    }
  },
  "include": [
    "./src",
    "./vite.config.ts"
  ]
}
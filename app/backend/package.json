{
    "name": "rebase-app-backend",
    "version": "0.0.1",
    "description": "Custom PostgreSQL backend for Rebase with real-time sync",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --watch=\"../shared/**/*\" --watch=\"../../packages/backend/src/**/*\" --conditions development src/index.ts",
        "build": "tsc --noEmit",
        "start": "tsx src/index.ts",
        "generate:schema": "tsx ../../packages/backend/src/generate-drizzle-schema.ts --collections=../shared/collections --output=src/schema.generated.ts",
        "db:pull": "DOTENV_CONFIG_PATH=../.env drizzle-kit pull",
        "db:generate": "pnpm generate:schema && tsx scripts/db-generate.ts",
        "db:migrate": "DOTENV_CONFIG_PATH=../.env drizzle-kit migrate",
        "db:push": "DOTENV_CONFIG_PATH=../.env drizzle-kit push",
        "db:studio": "DOTENV_CONFIG_PATH=../.env drizzle-kit studio"
    },
    "dependencies": {
        "@rebasepro/backend": "0.0.1",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "drizzle-orm": "^0.44.4",
        "express": "^5.1.0",
        "pg": "^8.11.3",
        "rebase-app-shared": "workspace:*",
        "ws": "^8.16.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.10.5",
        "@types/pg": "^8.6.5",
        "@types/ws": "^8.5.10",
        "drizzle-kit": "^0.31.4",
        "typescript": "^5.3.3"
    },
    "gitHead": "e42be25c08d53e4b59790f8619ba848cce455363",
    "private": true
}

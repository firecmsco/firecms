{
    "name": "@rebasepro/app-example",
    "version": "0.0.1",
    "description": "Complete Rebase application example with PostgreSQL backend",
    "private": true,
    "type": "module",
    "workspaces": [
        "frontend",
        "backend",
        "shared"
    ],
    "scripts": {
        "dev": "rebase dev",
        "build": "pnpm -r run build",
        "start": "pnpm --filter \"*-backend\" start",
        "db:generate": "rebase db generate",
        "db:migrate": "rebase db migrate",
        "db:pull": "rebase db pull",
        "db:push": "rebase db push",
        "db:studio": "rebase db studio",
        "schema:generate": "rebase schema generate",
        "generate:sdk": "rebase generate-sdk",
        "deploy": "pnpm run build && pnpm run start"
    },
    "devDependencies": {
        "@rebasepro/cli": "0.0.1",
        "@rebasepro/types": "0.0.1",
        "concurrently": "^8.2.2",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
